# Collect all keys into a JSON-compatible structure
to_json() {
  local indent="${1:-2}"
  python3 -c "
import json, sys, os
data = {}
keys = sorted(os.environ.keys())
for k in keys:
    if k.startswith('SYS_'):
        parts = k[4:].split('__')
        d = data
        for p in parts[:-1]:
            d = d.setdefault(p, {})
        d[parts[-1]] = os.environ[k]
print(json.dumps(data, indent=$indent))
" 2>/dev/null || {
    # Fallback: simple manual JSON using awk
    printf "{\n"
    local first=true
    for key in "${!SYS[@]}"; do
      $first || printf ",\n"
      first=false
      printf "  \"%s\": \"%s\"" "$key" "${SYS[$key]}"
    done
    printf "\n}\n"
  }
}

export_json() {
  # Build JSON directly without env var roundtrip
  python3 -c "
import json, re, sys

# Read from stdin as a simple key=value format
data = {}
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    idx = line.find('=')
    if idx < 0:
        continue
    key = line[:idx]
    val = line[idx+1:]
    parts = key.split('.')
    d = data
    for p in parts[:-1]:
        d = d.setdefault(p, {})
    d[parts[-1]] = val

print(json.dumps(data, indent=2))
" <<< "$(for key in "${!SYS[@]}"; do printf "%s=%s\n" "$key" "${SYS[$key]}"; done)" 2>/dev/null || {
    # Fallback: manually build JSON
    printf "{\n"
    local keys=() i=0
    for key in "${!SYS[@]}"; do
      keys+=("$key")
    done
    # Sort keys
    IFS=$'\n' keys=($(sort <<<"${keys[*]}")); unset IFS
    local first=true
    for key in "${keys[@]}"; do
      $first || printf ",\n"
      first=false
      # Escape special chars and wrap in quotes
      local escaped="${SYS[$key]}"
      escaped="${escaped//\\/\\\\}"
      escaped="${escaped//\"/\\\"}"
      escaped="${escaped//$'\n'/\\n}"
      escaped="${escaped//$'\t'/\\t}"
      printf '  "%s": "%s"' "$key" "$escaped"
    done
    printf "\n}\n"
  }
}

export_yaml() {
  export_json | python3 -c "
import json, sys, yaml
try:
    data = json.load(sys.stdin)
    yaml.dump(data, sys.stdout, default_flow_style=False, allow_unicode=True)
except Exception as e:
    print(f'error: {e}', file=sys.stderr)
    sys.exit(1)
" 2>/dev/null || {
    warn "YAML export requires PyYAML (pip install pyyaml), falling back to JSON-like output"
    export_json
  }
}

