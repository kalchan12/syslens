#!/usr/bin/env bash
# syslens - Linux System Inspection & Diagnostics Tool
#
# A fast, modular, cross-distribution system inspector that gathers
# comprehensive hardware, OS, and runtime information from /proc, /sys,
# and kernel interfaces before falling back to external utilities.

set -uo pipefail
IFS=$'\n\t'

VERSION="0.1.0"
export LC_ALL=C

# Colors
if [[ -t 1 ]] && [[ "${NO_COLOR:-}" != "1" ]]; then
  R="\033[1;31m"    G="\033[1;32m"    Y="\033[1;33m"
  B="\033[1;34m"    M="\033[1;35m"    C="\033[1;36m"
  W="\033[1;37m"    D="\033[0;37m"    NC="\033[0m"
  BOLD="\033[1m"    UNDER="\033[4m"
else
  R= G= Y= B= M= C= W= D= NC= BOLD= UNDER=
fi

# Box-drawing characters
H_LINE="─" V_LINE="│" TL="┌" TR="┐" BL="└" BR="┘"
TEE_DN="┬" TEE_UP="┴" TEE_LT="├" TEE_RT="┤" CROSS="┼"

die() { printf "${R}Error:${NC} %s\n" "$*" >&2; exit 1; }
warn() { printf "${Y}Warning:${NC} %s\n" "$*" >&2; }

safe_read() {
  local f="$1"
  if [[ -r "$f" ]]; then <"$f" tr -d '\0' 2>/dev/null || true; fi
}
safe_read_line() {
  safe_read "$1" | head -n1 | tr -d '[:space:]' || true
}
has_cmd() { command -v "$1" &>/dev/null; }

fmt_size_bytes() {
  local val=$1
  if (( val >= 1099511627776 )); then printf "%.2f TiB" "$(bc -l <<< "$val / 1099511627776" 2>/dev/null || true)"
  elif (( val >= 1073741824 )); then printf "%.2f GiB" "$(bc -l <<< "$val / 1073741824" 2>/dev/null || true)"
  elif (( val >= 1048576 )); then printf "%.2f MiB" "$(bc -l <<< "$val / 1048576" 2>/dev/null || true)"
  elif (( val >= 1024 )); then printf "%.2f KiB" "$(bc -l <<< "$val / 1024" 2>/dev/null || true)"
  else printf "%d B" "$val"; fi
}

# Data store
declare -A SYS=()
store() { SYS["$1"]="$2"; }
get() { echo "${SYS[$1]-}"; }

# ── Collectors ──────────────────────────────────

collect_machine() {
  store "machine.hostname" "$(hostname 2>/dev/null || uname -n)"
  if [[ -f /sys/devices/virtual/dmi/id/product_name ]]; then
    store "machine.product" "$(safe_read_line /sys/devices/virtual/dmi/id/product_name)"
    store "machine.vendor" "$(safe_read_line /sys/devices/virtual/dmi/id/sys_vendor)"
  fi
}

collect_cpu() {
  local cpuinfo
  cpuinfo=$(safe_read /proc/cpuinfo) || true
  if [[ -z "$cpuinfo" ]]; then
    has_cmd lscpu && while IFS=':' read -r key val; do
      key="${key// /_}"; key="${key,,}"; val="${val## }"
      case "$key" in
        model_name) store "cpu.model" "$val" ;;
        vendor_id) store "cpu.vendor" "$val" ;;
      esac
    done < <(lscpu 2>/dev/null)
  else
    while IFS=':' read -r key val; do
      key="${key#"${key%%[![:space:]]*}"}"
      key="${key%"${key##*[![:space:]]}"}"
      val="${val## }"
      case "$key" in
        "model name") store "cpu.model" "$val" ;;
        vendor_id) store "cpu.vendor" "$val" ;;
        flags) store "cpu.flags" "$val" ;;
        "cpu cores") store "cpu.cores" "$val" ;;
      esac
    done <<< "$cpuinfo"
  fi
  local cc; cc=$(grep -c "^processor" /proc/cpuinfo 2>/dev/null || echo "0")
  store "cpu.logical" "$cc"
  store "cpu.arch" "$(uname -m)"
}

collect_memory() {
  local meminfo; meminfo=$(safe_read /proc/meminfo) || true
  if [[ -n "$meminfo" ]]; then
    while IFS=':' read -r key val; do
      val="${val## }"; val="${val% kB}"
      case "$key" in
        MemTotal) store "memory.total_kb" "$val" ;;
        MemFree) store "memory.free_kb" "$val" ;;
        MemAvailable) store "memory.avail_kb" "$val" ;;
        SwapTotal) store "memory.swap_total_kb" "$val" ;;
        SwapFree) store "memory.swap_free_kb" "$val" ;;
      esac
    done <<< "$meminfo"
  fi
}

collect_os() {
  if [[ -f /etc/os-release ]]; then
    while IFS='=' read -r key val; do
      val="${val%\"}"; val="${val#\"}"
      case "$key" in
        PRETTY_NAME) store "os.pretty_name" "$val" ;;
        ID) store "os.id" "$val" ;;
        VERSION_ID) store "os.version_id" "$val" ;;
      esac
    done < /etc/os-release
  fi
  store "os.arch" "$(uname -m)"
  store "os.user" "$(whoami 2>/dev/null || id -un)"
}

collect_kernel() {
  store "kernel.release" "$(uname -r)"
  store "kernel.version" "$(uname -v)"
  store "kernel.machine" "$(uname -m)"
}

collect_uptime() {
  local secs; secs=$(safe_read_line /proc/uptime 2>/dev/null | awk '{print $1}' | cut -d. -f1) || true
  if [[ -n "$secs" ]]; then
    local d=$((secs/86400)) h=$(((secs%86400)/3600)) m=$(((secs%3600)/60)) s=$((secs%60))
    store "uptime.seconds" "$secs"
    store "uptime.display" "${d}d ${h}h ${m}m ${s}s"
  fi
}

# -- GPU --
collect_gpu() {
  local idx=0
  if has_cmd lspci; then
    while IFS= read -r line; do
      if [[ "$line" =~ VGA|3D|Display ]]; then
        local dev ven rev
        dev=$(echo "$line" | sed -n 's/^[^"]*"\([^"]*\)".*/\1/p')
        ven=$(echo "$line" | sed -n 's/^[^"]*"[^"]*"[[:space:]]*"\([^"]*\)".*/\1/p')
        rev=$(echo "$line" | sed -n 's/.*(rev \([^)]*\)).*/\1/p')
        store "gpu.${idx}.device" "$dev"
        store "gpu.${idx}.vendor" "$ven"
        store "gpu.${idx}.revision" "$rev"
        ((idx++)) || true
      fi
    done < <(lspci -mm 2>/dev/null || true)
  fi
  store "gpu.count" "$idx"
}

# -- Storage --
collect_storage() {
  local idx=0
  if has_cmd lsblk; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local name size type
      name=$(echo "$line" | awk '{print $1}')
      size=$(echo "$line" | awk '{print $2}')
      type=$(echo "$line" | awk '{print $3}')
      [[ "$type" != "disk" ]] && continue
      local model
      model=$(lsblk -dln -o MODEL "/dev/$name" 2>/dev/null | head -1)
      model="${model:- }"
      store "storage.${idx}.name" "$name"
      store "storage.${idx}.size" "$size"
      store "storage.${idx}.model" "$model"
      ((idx++)) || true
    done < <(lsblk -dln -o NAME,SIZE,TYPE 2>/dev/null)
    store "storage.count" "$idx"
  fi
  # Filesystem usage
  local fidx=0
  while IFS= read -r line; do
    local fs size used avail use mount
    fs=$(echo "$line" | awk '{print $1}')
    size=$(echo "$line" | awk '{print $2}')
    used=$(echo "$line" | awk '{print $3}')
    avail=$(echo "$line" | awk '{print $4}')
    use=$(echo "$line" | awk '{print $5}' | tr -d '%')
    mount=$(echo "$line" | awk '{print $6}')
    [[ "$fs" == "Filesystem" ]] && continue
    [[ "$fs" == "tmpfs" || "$fs" == "devtmpfs" || "$fs" == "efivarfs" ]] && continue
    store "fs.${fidx}.filesystem" "$fs"
    store "fs.${fidx}.size" "$size"
    store "fs.${fidx}.used" "$used"
    store "fs.${fidx}.avail" "$avail"
    store "fs.${fidx}.use_pct" "$use"
    store "fs.${fidx}.mount" "$mount"
    ((fidx++)) || true
  done < <(df -h 2>/dev/null | tail -n +2)
  store "fs.count" "$fidx"
}

# -- Battery --
collect_battery() {
  local bidx=0
  for bat in /sys/class/power_supply/BAT[0-9]*; do
    [[ -d "$bat" ]] || continue
    local name="${bat##*/}"
    store "battery.${bidx}.name" "$name"
    store "battery.${bidx}.status" "$(safe_read_line "$bat/status")"
    local cap
    cap=$(safe_read_line "$bat/capacity")
    store "battery.${bidx}.capacity" "$cap"
    local energy_full energy_now voltage_now
    energy_full=$(safe_read_line "$bat/energy_full" 2>/dev/null || echo "0")
    energy_now=$(safe_read_line "$bat/energy_now" 2>/dev/null || echo "0")
    voltage_now=$(safe_read_line "$bat/voltage_now" 2>/dev/null || echo "0")
    store "battery.${bidx}.energy_full" "$energy_full"
    store "battery.${bidx}.energy_now" "$energy_now"
    store "battery.${bidx}.voltage" "$voltage_now"
    store "battery.${bidx}.technology" "$(safe_read_line "$bat/technology")"
    store "battery.${bidx}.model" "$(safe_read_line "$bat/model_name")"
    store "battery.${bidx}.manufacturer" "$(safe_read_line "$bat/manufacturer")"
    ((bidx++)) || true
  done
  store "battery.count" "$bidx"
}

# -- Fans --
collect_fans() {
  local fidx=0
  if has_cmd sensors; then
    while IFS= read -r line; do
      if [[ "$line" =~ ([0-9]+)\ RPM ]]; then
        local rpm="${BASH_REMATCH[1]}"
        local label=""
        [[ "$line" =~ ^([^:]+): ]] && label="${BASH_REMATCH[1]}"
        store "fan.${fidx}.name" "$label"
        store "fan.${fidx}.rpm" "$rpm"
        ((fidx++)) || true
      fi
    done < <(sensors 2>/dev/null || true)
  fi
  store "fan.count" "$fidx"
}

# -- Temperatures --
collect_temps() {
  local tidx=0
  for zone in /sys/class/thermal/thermal_zone[0-9]*; do
    [[ -d "$zone" ]] || continue
    local temp type
    temp=$(safe_read_line "$zone/temp" 2>/dev/null || echo "0")
    type=$(safe_read_line "$zone/type" 2>/dev/null || echo "unknown")
    if [[ "$temp" -gt 0 ]]; then
      local temp_c
      temp_c=$(bc -l <<< "$temp / 1000" 2>/dev/null || echo "0")
      store "temp.${tidx}.name" "$type"
      store "temp.${tidx}.celsius" "$(printf "%.1f" "$temp_c")"
      ((tidx++)) || true
    fi
  done
  store "temp.count" "$tidx"
}

# -- Displays --
collect_displays() {
  local idx=0
  if has_cmd xrandr && [[ -n "${DISPLAY:-}" ]]; then
    while IFS= read -r line; do
      if [[ "$line" =~ ^([a-zA-Z0-9_-]+)\ connected ]]; then
        local display_name="${BASH_REMATCH[1]}"
        store "display.${idx}.name" "$display_name"
        if [[ "$line" =~ ([0-9]+)x([0-9]+)\+([0-9]+)\+([0-9]+) ]]; then
          store "display.${idx}.width" "${BASH_REMATCH[1]}"
          store "display.${idx}.height" "${BASH_REMATCH[2]}"
        fi
        if [[ "$line" =~ ([0-9.]+)mm\ x\ ([0-9.]+)mm ]]; then
          store "display.${idx}.width_mm" "${BASH_REMATCH[1]}"
          store "display.${idx}.height_mm" "${BASH_REMATCH[2]}"
        fi
        ((idx++)) || true
      fi
    done < <(xrandr --current 2>/dev/null || true)
  fi
  store "display.count" "$idx"
  for bl in /sys/class/backlight/*/brightness; do
    [[ -r "$bl" ]] || continue
    store "display.backlight" "$(safe_read_line "$bl")"
    store "display.max_backlight" "$(safe_read_line "${bl%/*}/max_brightness")"
  done
}

# -- Motherboard --
collect_motherboard() {
  if [[ -d /sys/devices/virtual/dmi/id ]]; then
    store "board.vendor" "$(safe_read_line /sys/devices/virtual/dmi/id/board_vendor)"
    store "board.name" "$(safe_read_line /sys/devices/virtual/dmi/id/board_name)"
    store "board.version" "$(safe_read_line /sys/devices/virtual/dmi/id/board_version)"
    store "board.serial" "$(safe_read_line /sys/devices/virtual/dmi/id/board_serial)"
  fi
}

# -- BIOS --
collect_bios() {
  if [[ -d /sys/devices/virtual/dmi/id ]]; then
    store "bios.vendor" "$(safe_read_line /sys/devices/virtual/dmi/id/bios_vendor)"
    store "bios.version" "$(safe_read_line /sys/devices/virtual/dmi/id/bios_version)"
    store "bios.date" "$(safe_read_line /sys/devices/virtual/dmi/id/bios_date)"
    store "bios.release" "$(safe_read_line /sys/devices/virtual/dmi/id/bios_release)"
    store "bios.ec_firmware" "$(safe_read_line /sys/devices/virtual/dmi/id/ec_firmware_release)"
  fi
  if [[ -d /sys/firmware/efi ]]; then
    store "bios.mode" "UEFI"
  else
    store "bios.mode" "Legacy BIOS"
  fi
}

collect_all() {
  collect_machine; collect_cpu; collect_memory; collect_os; collect_kernel; collect_uptime
  collect_gpu; collect_storage; collect_battery; collect_fans; collect_temps
  collect_displays; collect_motherboard; collect_bios
  collect_network; collect_audio; collect_usb; collect_pci
  collect_security; collect_virtualization; collect_processes; collect_system_load
  collect_cpu_load

# -- Network --
collect_network() {
  local idx=0
  for net in /sys/class/net/*; do
    [[ -d "$net" ]] || continue
    local ifname="${net##*/}"
    [[ "$ifname" == "lo" ]] && continue
    store "net.${idx}.name" "$ifname"
    store "net.${idx}.address" "$(safe_read_line "$net/address")"
    local duplex speed operstate
    duplex="$(safe_read_line "$net/duplex" 2>/dev/null || true)"
    speed="$(safe_read_line "$net/speed" 2>/dev/null || true)"
    operstate="$(safe_read_line "$net/operstate" 2>/dev/null || echo "unknown")"
    store "net.${idx}.duplex" "$duplex"
    store "net.${idx}.speed" "$speed"
    store "net.${idx}.state" "$operstate"
    ((idx++)) || true
  done
  store "net.count" "$idx"
  # Traffic stats
  while IFS= read -r line; do
    if [[ "$line" =~ ^[[:space:]]*([^:]+):[[:space:]]*(.*) ]]; then
      local dev_name="${BASH_REMATCH[1]}" stats="${BASH_REMATCH[2]}"
      local rx tx
      rx=$(echo "$stats" | awk '{print $1}')
      tx=$(echo "$stats" | awk '{print $9}')
      for ((i=0; i<idx; i++)); do
        [[ "$(get net.${i}.name)" == "$dev_name" ]] && store "net.${i}.rx_bytes" "$rx" && store "net.${i}.tx_bytes" "$tx"
      done
    fi
  done < /proc/net/dev
  store "net.default_gateway" "$(ip route show default 2>/dev/null | awk '{print $3}')"
}

# -- Audio --
collect_audio() {
  local idx=0
  if has_cmd lspci; then
    while IFS= read -r line; do
      if [[ "$line" =~ Audio|HDMI|HDA|AC97 ]]; then
        local dev pci
        dev=$(echo "$line" | sed 's/.*: //; s/ (.*//')
        pci=$(echo "$line" | awk '{print $1}')
        store "audio.${idx}.device" "$dev"
        store "audio.${idx}.pci" "$pci"
        ((idx++)) || true
      fi
    done < <(lspci 2>/dev/null || true)
  fi
  store "audio.count" "$idx"
  store "audio.alsa_info" "$(safe_read /proc/asound/version 2>/dev/null | head -1)"
}

# -- USB --
collect_usb() {
  if has_cmd lsusb; then
    local idx=0
    while IFS= read -r line; do
      if [[ "$line" =~ ^Bus ]]; then
        local bus dev id desc
        bus=$(echo "$line" | awk '{print $2}')
        dev=$(echo "$line" | awk '{print $4}' | tr -d ':')
        id=$(echo "$line" | awk '{print $6}')
        desc=$(echo "$line" | sed 's/.*://; s/^[[:space:]]*//')
        store "usb.${idx}.bus" "$bus"
        store "usb.${idx}.device" "$dev"
        store "usb.${idx}.id" "$id"
        store "usb.${idx}.description" "$desc"
        ((idx++)) || true
      fi
    done < <(lsusb 2>/dev/null || true)
    store "usb.count" "$idx"
  fi
}

# -- PCI --
collect_pci() {
  if has_cmd lspci; then
    local idx=0
    while IFS= read -r line; do
      local slot desc
      slot=$(echo "$line" | awk '{print $1}')
      desc=$(echo "$line" | sed 's/^[^ ]* //; s/ (.*//')
      store "pci.${idx}.slot" "$slot"
      store "pci.${idx}.description" "$desc"
      ((idx++)) || true
    done < <(lspci 2>/dev/null || true)
    store "pci.count" "$idx"
  fi
}

# -- Security --
collect_security() {
  if [[ -d /sys/kernel/security/apparmor ]]; then
    store "security.apparmor" "enabled"
    store "security.apparmor_profiles" "$(cat /sys/kernel/security/apparmor/profiles 2>/dev/null | wc -l)"
  else
    store "security.apparmor" "disabled"
  fi
  if has_cmd getenforce; then store "security.selinux" "$(getenforce 2>/dev/null)"
  else store "security.selinux" "not_present"; fi
  if [[ -f /proc/sys/kernel/randomize_va_space ]]; then
    local aslr; aslr=$(safe_read_line /proc/sys/kernel/randomize_va_space)
    case "$aslr" in
      0) store "security.aslr" "disabled" ;;
      1) store "security.aslr" "partial" ;;
      2) store "security.aslr" "full" ;;
    esac
  fi
  if [[ -f /proc/sys/kernel/yama/ptrace_scope ]]; then
    store "security.ptrace_scope" "$(safe_read_line /proc/sys/kernel/yama/ptrace_scope)"
  fi
  if has_cmd ufw; then store "security.ufw" "$(ufw status 2>/dev/null | head -1)"; fi
  local sb_file; sb_file=$(ls /sys/firmware/efi/efivars/SecureBoot-* 2>/dev/null | head -1) || true
  if [[ -n "$sb_file" && -f "$sb_file" ]]; then
    local sb; sb=$(od -An -t u1 "$sb_file" 2>/dev/null | head -1 | awk '{print $2}')
    store "security.secure_boot" "$( [[ "$sb" == "1" ]] && echo "enabled" || echo "disabled" )"
  else
    store "security.secure_boot" "N/A"
  fi
}

# -- Virtualization --
collect_virtualization() {
  local virt=""
  if has_cmd systemd-detect-virt; then
    local sdv; sdv=$(systemd-detect-virt 2>/dev/null || echo "none")
    [[ "$sdv" != "none" ]] && virt="$sdv"
  fi
  if [[ -z "$virt" && -f /sys/devices/virtual/dmi/id/product_name ]]; then
    local prod; prod=$(safe_read_line /sys/devices/virtual/dmi/id/product_name)
    case "$prod" in *VMware*) virt="VMware" ;; *VirtualBox*) virt="VirtualBox" ;; *KVM*|*QEMU*) virt="KVM/QEMU" ;; *Xen*) virt="Xen" ;; esac
  fi
  if [[ -z "$virt" ]]; then
    local cpuinfo; cpuinfo=$(safe_read /proc/cpuinfo)
    echo "$cpuinfo" | grep -qi "hypervisor" && virt="hypervisor"
  fi
  store "virtualization.type" "${virt:-none}"
  store "virtualization.is_vm" "$( [[ -n "$virt" ]] && echo "yes" || echo "no" )"
}

# -- Processes --
collect_processes() {
  store "process.total" "$(ps -e 2>/dev/null | wc -l | awk '{print $1-1}')"
  store "process.running" "$(ps -e -o state= 2>/dev/null | grep -c "^R" || echo "0")"
  store "process.sleeping" "$(ps -e -o state= 2>/dev/null | grep -c "^S" || echo "0")"
  store "process.zombie" "$(ps -e -o state= 2>/dev/null | grep -c "^Z" || echo "0")"
  store "process.stopped" "$(ps -e -o state= 2>/dev/null | grep -c "^T" || echo "0")"
  local top_idx=0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local pid cpu mem cmd
    pid=$(echo "$line" | awk '{print $1}')
    cpu=$(echo "$line" | awk '{print $3}')
    mem=$(echo "$line" | awk '{print $4}')
    cmd=$(echo "$line" | awk '{for(i=6;i<=NF;i++) printf "%s ", $i; print ""}' | xargs | head -c 55)
    [[ "$top_idx" -ge 10 ]] && break
    store "process.top.${top_idx}.pid" "$pid"
    store "process.top.${top_idx}.cpu" "$cpu"
    store "process.top.${top_idx}.mem" "$mem"
    store "process.top.${top_idx}.cmd" "$cmd"
    ((top_idx++)) || true
  done < <(ps -eo pid,ppid,%cpu,%mem,rss,args --sort=-%cpu 2>/dev/null | tail -n +2 | head -10)
  store "process.top_count" "$top_idx"
}

# -- System load --
collect_system_load() {
  store "system.fd_count" "$(ls /proc/*/fd 2>/dev/null | wc -l || echo "0")"
  store "system.users" "$(users | wc -w)"
  if has_cmd systemctl; then
    store "system.services_running" "$(systemctl list-units --type=service --state=running 2>/dev/null | grep -c "running" || echo "0")"
  fi
}

# -- CPU load averages --
collect_cpu_load() {
  local loadavg; loadavg=$(< /proc/loadavg) 2>/dev/null || true
  store "cpu.load_1m" "$(echo "${loadavg:-}" | awk '{print $1}')"
  store "cpu.load_5m" "$(echo "${loadavg:-}" | awk '{print $2}')"
  store "cpu.load_15m" "$(echo "${loadavg:-}" | awk '{print $3}')"
  # Per-core frequencies
  if [[ -d /sys/devices/system/cpu ]]; then
    local idx=0
    for cpuf in /sys/devices/system/cpu/cpu[0-9]*/cpufreq/scaling_cur_freq; do
      if [[ -r "$cpuf" ]]; then
        local freq=$(< "$cpuf"); freq=$((freq / 1000))
        store "cpu.core.${idx}.freq" "$freq"; ((idx++)) || true
      fi
    done
    store "cpu.core_count" "$idx"
  fi
  # Physical cores
  local phys=0
  [[ -d /sys/devices/system/cpu ]] && for dir in /sys/devices/system/cpu/cpu[0-9]*/topology/core_id; do
    [[ -r "$dir" ]] || continue; phys=$((phys + 1))
  done 2>/dev/null || true
  store "cpu.physical_total" "$phys"
}

# ── CPU usage (needs brief sleep) ──────────────

collect_cpu_usage() {
  local stat prev_idle prev_total
  stat=$(safe_read /proc/stat | head -1) || true
  local user nice sys idle iowait irq softirq steal
  read -r _ user nice sys idle iowait irq softirq steal <<< "$stat"
  prev_total=$((user + nice + sys + idle + iowait + irq + softirq + steal))
  prev_idle=$((idle + iowait))
  sleep 0.3
  stat=$(safe_read /proc/stat | head -1) || true
  read -r _ user nice sys idle iowait irq softirq steal <<< "$stat"
  local total=$((user + nice + sys + idle + iowait + irq + softirq + steal))
  local idl=$((idle + iowait))
  local total_d=$((total - prev_total))
  local idle_d=$((idl - prev_idle))
  if (( total_d > 0 )); then
    local usage=$(( 100 * (total_d - idle_d) / total_d ))
    store "cpu.usage_percent" "$usage"
  fi
}

# ── Terminal output ─────────────────────────────

section() {
  local title="$1" color="${2:-$B}" len=60
  local pad=$(( (len - ${#title} - 2) / 2 ))
  local left=$pad right=$(( len - ${#title} - 2 - pad ))
  printf "\n${color}${BOLD}%s" "$TL"
  printf "%0.s${H_LINE}" $(seq 1 $left)
  printf " %s " "$title"
  printf "%0.s${H_LINE}" $(seq 1 $right)
  printf "%s${NC}\n" "$TR"
}

kv() { local k="$1" v="$2" c="${3:-$NC}"; printf "${D}${V_LINE}${NC} ${BOLD}%-20s${NC} ${c}%s${NC}\n" "$k:" "$v"; }
section_end() { printf "${D}%s${NC}\n" "${BL}$(printf "%0.s${H_LINE}" $(seq 1 62))${BR}"; }

render_machine() {
  section "Machine"
  kv "Hostname" "$(get machine.hostname)" "$G"
  kv "Product" "$(get machine.product)"
  kv "Vendor" "$(get machine.vendor)"
  section_end
}

render_cpu() {
  section "CPU"
  kv "Model" "$(get cpu.model)" "$G"
  kv "Vendor" "$(get cpu.vendor)"
  kv "Cores" "$(get cpu.logical)"
  section_end
}

render_memory() {
  section "Memory"
  local t=$(($(get memory.total_kb)/1024)) a=$(($(get memory.avail_kb)/1024))
  kv "Total" "${t} MiB"
  kv "Available" "${a} MiB"
  if [[ "$t" -gt 0 ]]; then
    local pct=$(( (t-a)*100/t )) bar_len=30 filled=$((pct*bar_len/100))
    local bar="[${G}"; for ((i=0;i<filled;i++)); do bar+="█"; done
    bar+="${D}"; for ((i=0;i<bar_len-filled;i++)); do bar+="░"; done
    bar+="${NC}] ${pct}%"
    kv "Usage" "$bar"
  fi
  section_end
}

render_os() {
  section "Operating System"
  kv "OS" "$(get os.pretty_name)" "$G"
  kv "Version" "$(get os.version_id)"
  kv "Architecture" "$(get os.arch)"
  kv "User" "$(get os.user)"
  section_end
}

render_kernel() {
  section "Kernel"
  kv "Release" "$(get kernel.release)" "$G"
  kv "Version" "$(get kernel.version)"
  section_end
}

render_uptime() {
  section "Uptime"
  kv "Uptime" "$(get uptime.display)"
  section_end
}

render_gpu() {
  local c=$(get gpu.count)
  section "GPU"
  if [[ "$c" -gt 0 ]]; then
    for ((i=0; i<c; i++)); do
      kv "Device $((i+1))" "$(get gpu.${i}.device)"
      kv "  Vendor" "$(get gpu.${i}.vendor)" "$D"
    done
  else
    kv "GPU" "${D}N/A${NC}" "$D"
  fi
  section_end
}

render_storage() {
  local c=$(get storage.count)
  section "Storage"
  if [[ "$c" -gt 0 ]]; then
    for ((i=0; i<c; i++)); do
      kv "Disk $((i+1))" "/dev/$(get storage.${i}.name)"
      kv "  Size" "$(get storage.${i}.size)"
      local m=$(get storage.${i}.model); m="${m%% }"
      [[ -n "$m" ]] && kv "  Model" "$m" "$D"
    done
  fi
  local fc=$(get fs.count)
  if [[ "$fc" -gt 0 ]]; then
    printf "${D}${V_LINE}  %-20s %8s %8s %8s %5s${NC}\n" "Mount" "Size" "Used" "Avail" "Use%"
    for ((i=0; i<fc; i++)); do
      local m=$(get fs.${i}.mount) s=$(get fs.${i}.size) u=$(get fs.${i}.used)
      local a=$(get fs.${i}.avail) p=$(get fs.${i}.use_pct)
      local col=$NC; [[ -n "$p" ]] && (( p > 90 )) && col=$R; [[ -n "$p" ]] && (( p > 75 && p <= 90 )) && col=$Y
      printf "${D}${V_LINE}${NC}  %-20s %8s %8s %8s ${col}%3s%%${NC}\n" "$m" "$s" "$u" "$a" "$p"
    done
  fi
  section_end
}

render_battery() {
  local c=$(get battery.count)
  [[ "$c" -eq 0 ]] && return
  section "Battery"
  for ((i=0; i<c; i++)); do
    kv "Name" "$(get battery.${i}.name)"
    kv "  Status" "$(get battery.${i}.status)"
    local cap=$(get battery.${i}.capacity)
    local cap_col=$G; [[ -n "$cap" ]] && (( cap < 20 )) && cap_col=$R
    [[ -n "$cap" ]] && (( cap >= 20 && cap < 50 )) && cap_col=$Y
    [[ -n "$cap" ]] && kv "  Capacity" "${cap}%" "$cap_col"
    kv "  Technology" "$(get battery.${i}.technology)" "$D"
    kv "  Model" "$(get battery.${i}.model)" "$D"
    kv "  Manufacturer" "$(get battery.${i}.manufacturer)" "$D"
  done
  section_end
}

render_fans() {
  local c=$(get fan.count)
  [[ "$c" -eq 0 ]] && return
  section "Fans"
  for ((i=0; i<c; i++)); do
    local n=$(get fan.${i}.name); [[ -z "$n" ]] && n="Fan $((i+1))"
    kv "$n" "$(get fan.${i}.rpm) RPM"
  done
  section_end
}

render_temps() {
  local c=$(get temp.count)
  [[ "$c" -eq 0 ]] && return
  section "Temperatures"
  for ((i=0; i<c; i++)); do
    local cel=$(get temp.${i}.celsius) cint=${cel%.*}
    local col=$G; (( cint >= 80 )) && col=$R; (( cint >= 60 && cint < 80 )) && col=$Y
    kv "$(get temp.${i}.name)" "${cel}°C" "$col"
  done
  section_end
}

render_displays() {
  local c=$(get display.count)
  section "Displays"
  if [[ "$c" -gt 0 ]]; then
    for ((i=0; i<c; i++)); do
      local n=$(get display.${i}.name) w=$(get display.${i}.width) h=$(get display.${i}.height)
      [[ -n "$w" ]] && kv "Display $((i+1))" "${n}  ${w}x${h}" || kv "Display $((i+1))" "$n"
    done
  else
    kv "Displays" "${D}N/A${NC}" "$D"
  fi
  local bl=$(get display.backlight) mbl=$(get display.max_backlight)
  [[ -n "$bl" && "$mbl" -gt 0 ]] && kv "Brightness" "$((bl * 100 / mbl))%"
  section_end
}

render_motherboard() {
  local v=$(get board.vendor) n=$(get board.name)
  [[ -z "$v" && -z "$n" ]] && return
  section "Motherboard"
  kv "Vendor" "$v"
  kv "Model" "$n"
  kv "Version" "$(get board.version)"
  section_end
}

render_bios() {
  local v=$(get bios.vendor)
  [[ -z "$v" ]] && return
  section "BIOS"
  kv "Vendor" "$v"
  kv "Version" "$(get bios.version)"
  kv "Date" "$(get bios.date)"
  kv "Mode" "$(get bios.mode)"
  section_end
}

render_network() {
  local c=$(get net.count)
  section "Network"
  for ((i=0; i<c; i++)); do
    local n=$(get net.${i}.name) a=$(get net.${i}.address) s=$(get net.${i}.state) sp=$(get net.${i}.speed)
    local sc=$D; [[ "$s" == "up" ]] && sc=$G
    kv "Interface $((i+1))" "$n"
    kv "  MAC" "$a" "$D"
    kv "  State" "$s" "$sc"
    [[ -n "$sp" && "$sp" -gt 0 ]] && kv "  Speed" "${sp} Mbps"
    local rx=$(get net.${i}.rx_bytes) tx=$(get net.${i}.tx_bytes)
    [[ -n "$rx" ]] && kv "  RX" "$(fmt_size_bytes "$rx")" && kv "  TX" "$(fmt_size_bytes "$tx")"
  done
  local gw=$(get net.default_gateway); [[ -n "$gw" ]] && kv "Gateway" "$gw"
  section_end
}

render_audio() {
  local c=$(get audio.count)
  [[ "$c" -eq 0 ]] && return
  section "Audio"
  for ((i=0; i<c; i++)); do
    kv "Device $((i+1))" "$(get audio.${i}.device)"
    kv "  PCI" "$(get audio.${i}.pci)" "$D"
  done
  local alsa=$(get audio.alsa_info)
  [[ -n "$alsa" ]] && kv "ALSA" "$alsa" "$D"
  section_end
}

render_usb() {
  local c=$(get usb.count)
  section "USB"
  if [[ "$c" -gt 0 ]]; then
    kv "Devices" "$c"
    for ((i=0; i<c && i<8; i++)); do
      kv "  $((i+1))" "$(get usb.${i}.description) ($(get usb.${i}.id))" "$D"
    done
    (( c > 8 )) && kv "  ..." "${D}and $((c-8)) more${NC}" "$D"
  else
    kv "Devices" "${D}N/A${NC}" "$D"
  fi
  section_end
}

render_pci() {
  local c=$(get pci.count)
  section "PCI Devices"
  if [[ "$c" -gt 0 ]]; then
    local shown=0
    for ((i=0; i<c && shown<12; i++)); do
      local desc=$(get pci.${i}.description)
      if echo "$desc" | grep -qiE "VGA|3D|Audio|Net|USB|SATA|NVMe|AHCI|Ethernet|WiFi|Bluetooth|Display"; then
        kv "$(get pci.${i}.slot)" "$desc" "$D"; ((shown++)) || true
      fi
    done
    (( c > shown )) && kv "  ..." "${D}and $((c-shown)) more${NC}" "$D"
  fi
  section_end
}

render_security() {
  section "Security"
  local aa=$(get security.apparmor) se=$(get security.selinux) ufw=$(get security.ufw)
  local sb=$(get security.secure_boot) aslr=$(get security.aslr)
  [[ -n "$aa" ]] && kv "AppArmor" "$aa" "$( [[ "$aa" == "enabled" ]] && echo "$G" || echo "$R" )"
  [[ -n "$se" ]] && kv "SELinux" "$se" "$D"
  [[ -n "$ufw" ]] && kv "UFW" "$ufw" "$( [[ "$ufw" == "active" ]] && echo "$G" || echo "$Y" )"
  [[ -n "$sb" ]] && kv "Secure Boot" "$sb"
  [[ -n "$aslr" ]] && kv "ASLR" "$aslr"
  local yama=$(get security.ptrace_scope); [[ -n "$yama" ]] && kv "Ptrace Scope" "$yama"
  section_end
}

render_virtualization() {
  local virt=$(get virtualization.type) is_vm=$(get virtualization.is_vm)
  [[ "$virt" == "none" ]] && return
  section "Virtualization"
  kv "Type" "$( [[ "$is_vm" == "yes" ]] && echo "${Y}${virt}${NC}" || echo "$virt" )"
  section_end
}

render_processes() {
  section "Processes"
  kv "Total" "$(get process.total)"
  kv "Running" "$(get process.running)" "$G"
  kv "Sleeping" "$(get process.sleeping)" "$D"
  local z=$(get process.zombie); [[ -n "$z" && "$z" -gt 0 ]] && kv "Zombie" "${R}${z}${NC}" "$R"
  kv "Stopped" "$(get process.stopped)"
  local tc=$(get process.top_count)
  if [[ "$tc" -gt 0 ]]; then
    printf "${D}${V_LINE}  %6s %5s %5s %s${NC}\n" "PID" "CPU%" "MEM%" "Command"
    for ((i=0; i<tc; i++)); do
      printf "${D}${V_LINE}${NC}  %6s %4s%% %4s%% %s\n" "$(get process.top.${i}.pid)" \
        "$(get process.top.${i}.cpu)" "$(get process.top.${i}.mem)" "$(get process.top.${i}.cmd)"
    done
  fi
  section_end
}

render_system_load() {
  section "System Load"
  kv "Fds" "$(get system.fd_count)"
  kv "Users" "$(get system.users)"
  kv "Services" "$(get system.services_running)"
  section_end
}

# ── Exporters ──────────────────────────────────

export_json() {
  python3 -c "
import json, sys
data = {}
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    idx = line.find('=')
    if idx < 0: continue
    key, val = line[:idx], line[idx+1:]
    parts = key.split('.')
    d = data
    for p in parts[:-1]:
        d = d.setdefault(p, {})
    d[parts[-1]] = val
print(json.dumps(data, indent=2))
" <<< "$(for k in "${!SYS[@]}"; do printf "%s=%s\n" "$k" "${SYS[$k]}"; done)" 2>/dev/null || {
    printf "{\n"; local first=true
    for k in "${!SYS[@]}"; do
      $first || printf ",\n"; first=false
      local v="${SYS[$k]}"; v="${v//\\/\\\\}"; v="${v//\"/\\\"}"
      printf '  "%s": "%s"' "$k" "$v"
    done; printf "\n}\n"
  }
}

export_yaml() {
  export_json | python3 -c "
import json, sys, yaml
try:
    data = json.load(sys.stdin)
    yaml.dump(data, sys.stdout, default_flow_style=False, allow_unicode=True)
except Exception:
    print('error: YAML export requires PyYAML (pip install pyyaml)', file=sys.stderr)
    sys.exit(1)
" 2>/dev/null || export_json
}

# Markdown: iterate sections that have data
export_markdown() {
  printf "# syslens System Report\n\n**Date:** %s  \n**Host:** %s\n\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$(get machine.hostname)"
  local sections=(
    "Machine|machine.hostname|Hostname|machine.product|Product|machine.vendor|Vendor"
    "OS|os.pretty_name|OS|os.version_id|Version|os.arch|Architecture|os.hostname|Hostname|os.user|User"
    "Kernel|kernel.release|Release|kernel.version|Version|kernel.machine|Architecture"
    "CPU|cpu.model|Model|cpu.logical|Cores|cpu.mhz|MHz|cpu.load_1m|Load 1m"
    "Memory|memory.total_kb|Total (KiB)|memory.avail_kb|Available (KiB)|memory.free_kb|Free (KiB)"
  )
  for entry in "${sections[@]}"; do
    local title="${entry%%|*}" rest="${entry#*|}" has_data=false rows=""
    IFS='|' read -ra fields <<< "$rest"
    for ((j=0; j<${#fields[@]}; j+=2)); do
      local fval="$(get "${fields[$j]}")"
      if [[ -n "$fval" && "$fval" != "0" ]]; then
        has_data=true; rows+="| ${fields[$((j+1))]} | $fval |\n"
      fi
    done
    $has_data && printf "## %s\n\n| Key | Value |\n| --- | --- |\n%b\n" "$title" "$rows"
  done
  printf "\n---\n*Generated by syslens v%s*\n" "$VERSION"
}

export_html() {
  local style="<style>
    body{font-family:system-ui,sans-serif;background:#0d1117;color:#c9d1d9;padding:20px;max-width:1000px;margin:auto}
    h1,h2{color:#58a6ff;border-bottom:1px solid #30363d}
    table{width:100%;border-collapse:collapse;margin:10px 0}
