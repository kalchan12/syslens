#  MINIMAL RENDER
# ──────────────────────────────────────────────

render_minimal() {
  printf "\n${BOLD}${C}syslens${NC} ${D}— System Overview${NC}\n"
  printf "${D}%s${NC}\n" "$(printf "%0.s${H_LINE}" $(seq 1 62))"
  kv "OS" "$(get os.pretty_name)" "$G"
  kv "  Arch" "$(get os.arch)"
  kv "  Kernel" "$(get kernel.release)" "$D"
  kv "CPU" "$(get cpu.model)" "$C"
  kv "  Cores" "$(get cpu.logical) logical / $(get cpu.physical_total) physical"
  local l1=$(get cpu.load_1m) l5=$(get cpu.load_5m) l15=$(get cpu.load_15m)
  kv "  Load" "${l1} / ${l5} / ${l15} (1/5/15m)"
  local u=$(get cpu.usage_percent)
  if [[ -n "$u" ]]; then
    local uc=$G; (( u > 80 )) && uc=$R; (( u >= 50 && u <= 80 )) && uc=$Y
    kv "  Usage" "${uc}${u}%${NC}"
  fi
  local tk="${SYS[memory.total_kb]:-0}" ak="${SYS[memory.avail_kb]:-0}"
  local tm=$((tk/1024))
  local am=$((ak/1024))
  local um=$((tm-am))
  local pm=0
  (( tm > 0 )) && pm=$(( (tm-am)*100/tm ))
  local bl=30
  local fl=$((pm*bl/100))
  local bar="[${G}"; for ((i=0;i<fl;i++)); do bar+="█"; done
  bar+="${D}"; for ((i=0;i<bl-fl;i++)); do bar+="░"; done; bar+="${NC}]"
  kv "Memory" "${um} / ${tm} MiB used"
  kv "  Usage" "${bar} ${pm}%"
  local s=$(get storage.count)
  if [[ "$s" -gt 0 ]]; then
    for ((i=0; i<s; i++)); do
      local dn=$(get storage.${i}.name) ds=$(get storage.${i}.size)
      kv "Disk $((i+1))" "/dev/${dn}  (${ds})" "$D"
    done
  fi
  local fc=$(get fs.count)
  for ((i=0; i<fc; i++)); do
    local m=$(get fs.${i}.mount) p=$(get fs.${i}.use_pct)
    [[ "$m" != "/" && "$m" != "/home" && "$m" != "/boot" ]] && continue
    local pc=$G; (( p > 90 )) && pc=$R; (( p >= 75 && p <= 90 )) && pc=$Y
    kv "  ${m}" "${pc}${p}% used${NC}"
  done
  kv "Uptime" "$(get uptime.display)" "$C"
  kv "Processes" "$(get process.total) total, $(get process.running) running"
  kv "Boot" "$(date -d "@$(get uptime.boot_time)" '+%Y-%m-%d %H:%M:%S' 2>/dev/null)" "$D"
  printf "${D}%s${NC}\n" "$(printf "%0.s${H_LINE}" $(seq 1 62))"
}

