  collect_cpu_usage
}

# ──────────────────────────────────────────────
#  TERMINAL RENDERER
# ──────────────────────────────────────────────

render_machine() {
  section "Machine"
  checked_kv "Hostname" "$(get machine.hostname)"
  checked_kv "Product" "$(get machine.product)"
  checked_kv "Vendor" "$(get machine.vendor)"
  checked_kv "Family" "$(get machine.family)"
  checked_kv "UUID" "$(get machine.uuid)"
  section_end
}

render_cpu() {
  section "CPU"
  checked_kv "Model" "$(get cpu.model)"
  checked_kv "Vendor" "$(get cpu.vendor)"
  checked_kv "Architecture" "$(get cpu.arch)"
  checked_kv "Logical Cores" "$(get cpu.logical)"
  checked_kv "Physical Cores" "$(get cpu.physical_total)"
  checked_kv "Max MHz" "$(get cpu.max_mhz)"
  checked_kv "Current MHz" "$(get cpu.mhz)"
  checked_kv "Flags" "$(get cpu.flags)" "$D"
  local usage=$(get cpu.usage_percent)
  if [[ -n "$usage" ]]; then
    if (( usage > 80 )); then
      kv "Usage" "${usage}%" "$R"
    elif (( usage > 50 )); then
      kv "Usage" "${usage}%" "$Y"
    else
      kv "Usage" "${usage}%" "$G"
    fi
  fi
  kv "Load (1/5/15m)" "$(get cpu.load_1m) / $(get cpu.load_5m) / $(get cpu.load_15m)"
  checked_kv "Cache" "$(get cpu.cache)"

  # Per-core frequencies
  local cc=$(get cpu.core_count)
  if [[ -n "$cc" && "$cc" -gt 0 ]]; then
    sub_header "Per-Core Frequencies"
    local line=""
    for ((i=0; i<cc; i++)); do
      local freq=$(get "cpu.core.${i}.freq")
      line+=" Core${i}:${freq}MHz"
    done
    printf "${D}${V_LINE}${NC}  %s\n" "$line"
  fi
  section_end
}

render_gpu() {
  local count=$(get gpu.count)
  section "GPU"
  if [[ "$count" -gt 0 ]]; then
    for ((i=0; i<count; i++)); do
      checked_kv "Device $((i+1))" "$(get "gpu.${i}.device")"
      kv "  Vendor" "$(get "gpu.${i}.vendor")" "$D"
    done
  else
    kv "GPU" "${D}No GPU information found${NC}" "$D"
  fi
  section_end
}

render_memory() {
  section "Memory"
  local total=$(get memory.total_kb)
  local avail=$(get memory.avail_kb)
  local free=$(get memory.free_kb)
  local total_mib=$((total / 1024))
  local avail_mib=$((avail / 1024))
  local free_mib=$((free / 1024))
  local used_mib=$((total_mib - avail_mib))
  local pct=0
  if [[ "$total" -gt 0 ]]; then
    pct=$(( (total - avail) * 100 / total ))
  fi

  kv "Total" "${total_mib} MiB"
  if (( pct > 80 )); then
    kv "Used" "${used_mib} MiB" "$R"
  elif (( pct > 50 )); then
    kv "Used" "${used_mib} MiB" "$Y"
  else
    kv "Used" "${used_mib} MiB"
  fi
  kv "Available" "${avail_mib} MiB"
  kv "Free" "${free_mib} MiB"

  # Memory bar
  if [[ "$total" -gt 0 ]]; then
    local bar_len=30
    local filled=$(( pct * bar_len / 100 ))
    local empty=$(( bar_len - filled ))
    local bar=""
    bar+="["
    if (( pct > 80 )); then
      bar+="${R}"
    elif (( pct > 50 )); then
      bar+="${Y}"
    else
      bar+="${G}"
    fi
    for ((i=0; i<filled; i++)); do bar+="█"; done
    bar+="${D}"
    for ((i=0; i<empty; i++)); do bar+="░"; done
    bar+="${NC}] ${pct}%"
    kv "Usage" "$bar"
  fi

  local swap_total=$(get memory.swap_total_kb)
  local swap_free=$(get memory.swap_free_kb)
  if [[ -n "$swap_total" && "$swap_total" -gt 0 ]]; then
    local swap_total_mib=$((swap_total / 1024))
    local swap_free_mib=$((swap_free / 1024))
    local swap_used=$((swap_total_mib - swap_free_mib))
    kv "Swap Total" "${swap_total_mib} MiB"
    kv "Swap Used" "${swap_used} MiB"
  fi
  section_end
}

render_storage() {
  section "Storage"
  local count=$(get storage.count)
  if [[ "$count" -gt 0 ]]; then
    for ((i=0; i<count; i++)); do
      local name=$(get "storage.${i}.name")
      local size=$(get "storage.${i}.size")
      local model=$(get "storage.${i}.model")
      local model_clean="${model%% }"
      kv "Disk $((i+1))" "/dev/${name}"
      kv "  Size" "$size"
      [[ -n "$model_clean" ]] && kv "  Model" "$model_clean" "$D"
    done
  else
    kv "Disks" "${D}No disk information${NC}" "$D"
  fi

  # Filesystems
  local fcount=$(get fs.count)
  if [[ "$fcount" -gt 0 ]]; then
    sub_header "Filesystem Usage"
    printf "${D}${V_LINE}  %-20s %8s %8s %8s %5s${NC}\n" "Mount" "Size" "Used" "Avail" "Use%"
    for ((i=0; i<fcount; i++)); do
      local mount=$(get "fs.${i}.mount")
      local size=$(get "fs.${i}.size")
      local used=$(get "fs.${i}.used")
      local avail=$(get "fs.${i}.avail")
      local use_pct=$(get "fs.${i}.use_pct")
      local col=$NC
      if [[ -n "$use_pct" && "$use_pct" -gt 90 ]]; then col=$R
      elif [[ -n "$use_pct" && "$use_pct" -gt 75 ]]; then col=$Y
      fi
      printf "${D}${V_LINE}${NC}  %-20s %8s %8s %8s ${col}%3s%%${NC}\n" "$mount" "$size" "$used" "$avail" "$use_pct"
    done
  fi
  section_end
}

render_battery() {
  local count=$(get battery.count)
  [[ "$count" -eq 0 ]] && return
  section "Battery"
  for ((i=0; i<count; i++)); do
    local name=$(get "battery.${i}.name")
    local status=$(get "battery.${i}.status")
    local cap=$(get "battery.${i}.capacity")
    local tech=$(get "battery.${i}.technology")
    local model=$(get "battery.${i}.model")
    local mfr=$(get "battery.${i}.manufacturer")
    local wh=$(get "battery.${i}.wh_design")
    kv "Name" "$name"
    kv "  Status" "$status"
    local cap_col=$G
    if [[ -n "$cap" ]]; then
      (( cap < 20 )) && cap_col=$R
      (( cap >= 20 && cap < 50 )) && cap_col=$Y
      kv "  Capacity" "${cap}%" "$cap_col"
    fi
    [[ -n "$tech" ]] && kv "  Technology" "$tech" "$D"
    [[ -n "$model" ]] && kv "  Model" "$model" "$D"
    [[ -n "$mfr" ]] && kv "  Manufacturer" "$mfr" "$D"
    [[ -n "$wh" ]] && kv "  Design" "${wh} Wh" "$D"
  done
  section_end
}

render_fans() {
  local count=$(get fan.count)
  [[ "$count" -eq 0 ]] && return
  section "Fans"
  for ((i=0; i<count; i++)); do
    local name=$(get "fan.${i}.name")
    local rpm=$(get "fan.${i}.rpm")
    [[ -z "$name" ]] && name="Fan $((i+1))"
    kv "$name" "${rpm} RPM"
  done
  section_end
}

render_temps() {
  local count=$(get temp.count)
  [[ "$count" -eq 0 ]] && return
  section "Temperatures"
  for ((i=0; i<count; i++)); do
    local name=$(get "temp.${i}.name")
    local celsius=$(get "temp.${i}.celsius")
    local col=$G
    if [[ -n "$celsius" ]]; then
      local cint=${celsius%.*}
      (( cint >= 80 )) && col=$R
      (( cint >= 60 && cint < 80 )) && col=$Y
    fi
    kv "$name" "${celsius}°C" "$col"
  done
  section_end
}

render_displays() {
  local count=$(get display.count)
  section "Displays"
  if [[ "$count" -gt 0 ]]; then
    for ((i=0; i<count; i++)); do
      local name=$(get "display.${i}.name")
      local w=$(get "display.${i}.width")
      local h=$(get "display.${i}.height")
      if [[ -n "$w" && -n "$h" ]]; then
        kv "Display $((i+1))" "$name"
        kv "  Resolution" "${w}x${h}"
      else
        kv "Display $((i+1))" "$name"
      fi
    done
  else
    kv "Displays" "${D}No display information${NC}" "$D"
  fi

  local bl; bl=$(get display.backlight)
  local mbl; mbl=$(get display.max_backlight)
  if [[ -n "$bl" && -n "$mbl" ]]; then
    local bl_pct=$((bl * 100 / mbl))
    kv "Brightness" "${bl_pct}%"
  fi
  section_end
}

render_motherboard() {
  local vendor=$(get board.vendor)
  local name=$(get board.name)
  [[ -z "$vendor" && -z "$name" ]] && return
  section "Motherboard"
  checked_kv "Vendor" "$vendor"
  checked_kv "Model" "$name"
  checked_kv "Version" "$(get board.version)"
  checked_kv "Serial" "$(get board.serial)" "$D"
  section_end
}

render_bios() {
  local vendor=$(get bios.vendor)
  [[ -z "$vendor" ]] && return
  section "BIOS"
  checked_kv "Vendor" "$vendor"
  checked_kv "Version" "$(get bios.version)"
  checked_kv "Date" "$(get bios.date)"
  checked_kv "Mode" "$(get bios.mode)"
  checked_kv "Release" "$(get bios.release)"
  section_end
}

render_network() {
  local count=$(get net.count)
  section "Network"
  for ((i=0; i<count; i++)); do
    local name=$(get "net.${i}.name")
    local addr=$(get "net.${i}.address")
    local state=$(get "net.${i}.state")
    local speed=$(get "net.${i}.speed")
    local rx=$(get "net.${i}.rx_bytes")
    local tx=$(get "net.${i}.tx_bytes")
    local state_col=$D
    [[ "$state" == "up" ]] && state_col=$G
    kv "Interface $((i+1))" "$name"
    kv "  MAC" "$addr" "$D"
    kv "  State" "$state" "$state_col"
    [[ -n "$speed" && "$speed" -gt 0 ]] && kv "  Speed" "${speed} Mbps"
    if [[ -n "$rx" ]]; then
      kv "  RX" "$(fmt_size_bytes "$rx")"
      kv "  TX" "$(fmt_size_bytes "$tx")"
    fi
  done
  local gw=$(get net.default_gateway)
  [[ -n "$gw" ]] && kv "Default Gateway" "$gw"
  section_end
}

render_audio() {
  local count=$(get audio.count)
  [[ "$count" -eq 0 ]] && return
  section "Audio"
  for ((i=0; i<count; i++)); do
    local dev=$(get "audio.${i}.device")
    local pci=$(get "audio.${i}.pci")
    kv "Device $((i+1))" "$dev"
    kv "  PCI" "$pci" "$D"
  done
  local alsa=$(get audio.alsa_info)
  [[ -n "$alsa" ]] && kv "ALSA" "$alsa" "$D"
  section_end
}

render_usb() {
  local count=$(get usb.count)
  section "USB"
  if [[ "$count" -gt 0 ]]; then
    kv "Devices" "$count"
    for ((i=0; i<count && i<8; i++)); do
      local desc=$(get "usb.${i}.description")
      local id=$(get "usb.${i}.id")
      kv "  $((i+1))" "${desc} (${id})" "$D"
    done
    if (( count > 8 )); then
      kv "  ..." "${D}and $((count - 8)) more${NC}" "$D"
    fi
  else
    kv "Devices" "${D}No USB information${NC}" "$D"
  fi
  section_end
}

render_pci() {
  local count=$(get pci.count)
  section "PCI Devices"
  if [[ "$count" -gt 0 ]]; then
    local displayed=0
    for ((i=0; i<count && displayed<12; i++)); do
      local slot=$(get "pci.${i}.slot")
      local desc=$(get "pci.${i}.description")
      # Show interesting devices
      if echo "$desc" | grep -qiE "VGA|3D|Audio|Net|USB|SATA|NVMe|AHCI|Ethernet|WiFi|Bluetooth|Display|HDMI"; then
        kv "$slot" "$desc" "$D"
        ((displayed++)) || true
      fi
    done
    if (( count > displayed )); then
      kv "  ..." "${D}and $((count - displayed)) more devices${NC}" "$D"
    fi
  else
    kv "Devices" "${D}No PCI information${NC}" "$D"
  fi
  section_end
}

render_os() {
  section "Operating System"
  checked_kv "OS" "$(get os.pretty_name)"
  checked_kv "ID" "$(get os.id)"
  checked_kv "Version" "$(get os.version_id)"
  checked_kv "Codename" "$(get os.codename)"
  checked_kv "Architecture" "$(get os.arch)"
  checked_kv "Hostname" "$(get os.hostname)"
  checked_kv "User" "$(get os.user)"
  checked_kv "Desktop" "$(get os.desktop)"
  checked_kv "Shell" "$(get os.shell)"
  checked_kv "Terminal" "$(get os.term)"
  section_end
}

render_kernel() {
  section "Kernel"
  checked_kv "Release" "$(get kernel.release)"
  checked_kv "Version" "$(get kernel.version)"
  checked_kv "Machine" "$(get kernel.machine)"
  checked_kv "Modules" "$(get kernel.modules)"
  checked_kv "Cmdline" "$(get kernel.cmdline)" "$D"
  section_end
}

render_security() {
  section "Security"
  local aa=$(get security.apparmor)
  local se=$(get security.selinux)
  local ufw=$(get security.ufw)
  local sb=$(get security.secure_boot)
  local aslr=$(get security.aslr)
  local yama=$(get security.ptrace_scope)

  if [[ -n "$aa" ]]; then
    local aa_col=$G
    [[ "$aa" == "disabled" ]] && aa_col=$R
    kv "AppArmor" "$aa" "$aa_col"
  fi
  if [[ -n "$se" ]]; then
    local se_col=$G
    [[ "$se" =~ disabled|not_present ]] && se_col=$D
    kv "SELinux" "$se" "$se_col"
  fi
  if [[ -n "$ufw" ]]; then
    local ufw_col=$G
    [[ "$ufw" =~ inactive|disabled ]] && ufw_col=$Y
    kv "UFW" "$ufw" "$ufw_col"
  fi
  if [[ -n "$sb" ]]; then
    local sb_col=$G
    [[ "$sb" == "disabled" ]] && sb_col=$R
    kv "Secure Boot" "$sb" "$sb_col"
  fi
  checked_kv "ASLR" "$aslr"
  checked_kv "Ptrace Scope" "$yama"
  section_end
}

render_virtualization() {
  local virt=$(get virtualization.type)
  local is_vm=$(get virtualization.is_vm)
  local container=$(get virtualization.container)
  virt="${virt:-none}"
  if [[ "$virt" == "none" ]] && [[ -z "$container" ]]; then
    return
  fi
  section "Virtualization"
  if [[ "$is_vm" == "yes" ]]; then
    kv "Hypervisor" "$virt" "$Y"
  elif [[ "$virt" != "none" ]]; then
    checked_kv "Type" "$virt"
  fi
  [[ -n "$container" ]] && kv "Container" "$container" "$Y"
  section_end
}

render_uptime() {
  section "Uptime"
  local display=$(get uptime.display)
  local days=$(get uptime.days)
  if [[ -n "$days" && "$days" -gt 30 ]]; then
    kv "Uptime" "$display" "$Y"
  else
    kv "Uptime" "$display"
  fi
  local btime=$(get uptime.boot_time)
  if [[ -n "$btime" ]]; then
    kv "Boot Time" "$(date -d "@$btime" '+%Y-%m-%d %H:%M:%S' 2>/dev/null)" "$D"
  fi
  section_end
}

render_processes() {
  section "Processes"
  local total=$(get process.total)
  local running=$(get process.running)
  local sleeping=$(get process.sleeping)
  local zombie=$(get process.zombie)
  local stopped=$(get process.stopped)
  kv "Total" "$total"
  kv "Running" "$running" "$G"
  kv "Sleeping" "$sleeping" "$D"
  if [[ -n "$zombie" && "$zombie" -gt 0 ]]; then
    kv "Zombie" "${R}${zombie}${NC}" "$R"
  fi
  kv "Stopped" "$stopped"

  local top_count=$(get process.top_count)
  if [[ "$top_count" -gt 0 ]]; then
    sub_header "Top CPU Processes"
    printf "${D}${V_LINE}  %6s %5s %5s %s${NC}\n" "PID" "CPU%" "MEM%" "Command"
    for ((i=0; i<top_count; i++)); do
      local pid=$(get "process.top.${i}.pid")
      local cpu=$(get "process.top.${i}.cpu")
      local mem=$(get "process.top.${i}.mem")
      local cmd=$(get "process.top.${i}.cmd")
      printf "${D}${V_LINE}${NC}  %6s %4s%% %4s%% %s\n" "$pid" "$cpu" "$mem" "$cmd"
    done
  fi
  section_end
}

render_system_load() {
  section "System Load"
  checked_kv "File Descriptors" "$(get system.fd_count)"
  checked_kv "Logged In Users" "$(get system.users)"
  checked_kv "Running Services" "$(get system.services_running)"
  section_end
}

