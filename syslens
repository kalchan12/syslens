# ──────────────────────────────────────────────
#  MAIN
# ──────────────────────────────────────────────

main() {
  local format="terminal"
  local cmd=""
  local args=()

  for arg in "$@"; do
    case "$arg" in
      --json) format="json" ;;
      --yaml) format="yaml" ;;
      --markdown) format="markdown" ;;
      --html) format="html" ;;
      --no-color) NO_COLOR=1 ;;
      --version) version_info ;;
      --help|help|-h) usage ;;
      *) args+=("$arg") ;;
    esac
  done

  cmd="${args[0]:-}"
  local arg1="${args[1]:-}"
  local arg2="${args[2]:-}"

  if [[ -n "$cmd" ]]; then
    case "$cmd" in
      menu|interactive) cmd_menu; return ;;
      minimal) collect_all; render_minimal; return ;;
      full) collect_all; render_all; return ;;
      doctor) collect_all_with_usage; cmd_doctor; return ;;
      watch)
        cmd_watch "${arg1:-2}"
        return
        ;;
      snapshot)
        case "${arg1:-}" in
          save) cmd_snapshot_save; return ;;
          list) cmd_snapshot_list; return ;;
          diff) cmd_snapshot_diff "${arg2:-}"; return ;;
          *) echo "Unknown snapshot subcommand: ${arg1:-}"; usage ;;
        esac
        return
        ;;
      machine|cpu|gpu|memory|storage|battery|fans|temps|displays|motherboard|bios|network|audio|usb|pci|os|kernel|security|virt|uptime|processes)
        collect_all
        local rcmd="$cmd"
        [[ "$rcmd" == "virt" ]] && rcmd="virtualization"
        [[ "$rcmd" == "cpu" ]] && collect_cpu_usage
        "render_${rcmd}"
        return
        ;;
      *)
        echo "Unknown command: $cmd"; usage ;;
    esac
  fi

  # Interactive menu when running interactively with no args
  if [[ -t 0 ]] && [[ -t 1 ]]; then
    cmd_menu
    return
  fi

  collect_all

  case "$format" in
    json)     export_json ;;
    yaml)     export_yaml ;;
    markdown) export_markdown ;;
    html)     export_html ;;
    *)        render_all ;;
  esac
}

main "$@"
