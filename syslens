collect_all() {
  collect_machine
  collect_cpu
  collect_memory
  collect_storage
  collect_gpu
  collect_battery
  collect_fans
  collect_temps
  collect_displays
  collect_motherboard
  collect_bios
  collect_network
  collect_audio
  collect_usb
  collect_pci
  collect_os
