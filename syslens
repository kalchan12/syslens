#!/usr/bin/env bash
# syslens - Linux System Inspection & Diagnostics Tool
#
# A fast, modular, cross-distribution system inspector that gathers
# comprehensive hardware, OS, and runtime information from /proc, /sys,
# and kernel interfaces before falling back to external utilities.
#
# Usage: syslens [command] [options]
#   syslens                    Interactive menu (default in terminal)
#   syslens minimal            Show concise system overview
#   syslens full               Show all system information
#   syslens cpu                Show CPU information only
#   syslens --json             Output as JSON
#   syslens doctor             Run health diagnostics
#   syslens watch              Live monitoring mode
#   syslens snapshot save      Save a system snapshot
#   syslens snapshot diff      Compare with saved snapshot
#   syslens help               Show this help message

set -uo pipefail
IFS=$'\n\t'

# ──────────────────────────────────────────────
#  VERSION & CONFIG
# ──────────────────────────────────────────────

VERSION="0.1.0"
SNAPSHOT_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/syslens/snapshots"
export LC_ALL=C
SELF="$0"

# ──────────────────────────────────────────────
#  COLOR / FORMATTING
# ──────────────────────────────────────────────

if [[ -t 1 ]] && [[ "${NO_COLOR:-}" != "1" ]]; then
  R="\033[1;31m"    # Red
  G="\033[1;32m"    # Green
  Y="\033[1;33m"    # Yellow
  B="\033[1;34m"    # Blue
  M="\033[1;35m"    # Magenta
  C="\033[1;36m"    # Cyan
  W="\033[1;37m"    # White
  D="\033[0;37m"    # Dim
  NC="\033[0m"      # Reset
  BOLD="\033[1m"
  UNDER="\033[4m"
else
  R= G= Y= B= M= C= W= D= NC= BOLD= UNDER=
fi

# Box-drawing characters
H_LINE="─"
V_LINE="│"
TL="┌"
TR="┐"
BL="└"
BR="┘"
TEE_DN="┬"
TEE_UP="┴"
TEE_LT="├"
TEE_RT="┤"
CROSS="┼"

# ──────────────────────────────────────────────
#  HELPERS
# ──────────────────────────────────────────────

die() { printf "${R}Error:${NC} %s\n" "$*" >&2; exit 1; }
warn() { printf "${Y}Warning:${NC} %s\n" "$*" >&2; }

# Read a file, return empty string if unavailable
safe_read() {
  local f="$1"
  if [[ -r "$f" ]]; then
    <"$f" tr -d '\0' 2>/dev/null || true
  fi
}

# Read first line of a file
safe_read_line() {
  safe_read "$1" | head -n1 | tr -d '[:space:]' || true
}

# Check if a command exists
has_cmd() { command -v "$1" &>/dev/null; }

# Convert bytes to human-readable (no bc needed)
fmt_size_bytes() {
  local val=$1
  if (( val >= 1099511627776 )); then
    local i=$((val / 1099511627776)) f=$(((val % 1099511627776) * 100 / 1099511627776))
    printf "%d.%02d TiB" "$i" "$f"
  elif (( val >= 1073741824 )); then
    local i=$((val / 1073741824)) f=$(((val % 1073741824) * 100 / 1073741824))
    printf "%d.%02d GiB" "$i" "$f"
  elif (( val >= 1048576 )); then
    local i=$((val / 1048576)) f=$(((val % 1048576) * 100 / 1048576))
    printf "%d.%02d MiB" "$i" "$f"
  elif (( val >= 1024 )); then
    local i=$((val / 1024)) f=$(((val % 1024) * 100 / 1024))
    printf "%d.%02d KiB" "$i" "$f"
  else
    printf "%d B" "$val"
  fi
}

# Print a section header for terminal output
section() {
  local title="$1"
  local color="${2:-$B}"
  local len=60
  local pad=$(( (len - ${#title} - 2) / 2 ))
  local left=$pad
  local right=$(( len - ${#title} - 2 - pad ))
  printf "\n${color}${BOLD}"
  printf "%s" "$TL"
  printf "%0.s${H_LINE}" $(seq 1 $left)
  printf " %s " "$title"
  printf "%0.s${H_LINE}" $(seq 1 $right)
  printf "%s${NC}\n" "$TR"
}

# Print a key-value row
kv() {
  local key="$1" val="$2" color="${3:-$NC}"
  printf "${D}${V_LINE}${NC} ${BOLD}%-20s${NC} ${color}%s${NC}\n" "$key:" "$val"
}

# Print a sub-header
sub_header() {
  local title="$1"
  printf "${D}${V_LINE}  ${TEE_LT} %s${NC}\n" "$title"
}

# Print a section footer
section_end() {
  printf "${D}%s${NC}\n" "${BL}$(printf "%0.s${H_LINE}" $(seq 1 62))${BR}"
}

checked_kv() {
  local key="$1" val="$2"
  if [[ -z "$val" || "$val" == "unknown" || "$val" == "0" ]]; then
    kv "$key" "${D}N/A${NC}" "$D"
  else
    kv "$key" "$val" "$G"
  fi
}

# ──────────────────────────────────────────────
#  DATA STORE
# ──────────────────────────────────────────────
# We use a flat associative array with dotted keys.
# e.g. store "cpu.model" "Intel ..."
# Arrays use: "cpu.cores.0.freq" etc., with "cpu.cores.count" for array size.

declare -A SYS=()

store() { SYS["$1"]="$2"; }
get() { echo "${SYS[$1]-}"; }
store_arr() {
  local base="$1" count_key="${base}.count"
  local idx=0
  SYS["$count_key"]=$#
  shift
  for val in "$@"; do
    SYS["${base}.${idx}"]="$val"
    ((idx++)) || true
  done
}
get_arr() {
  local base="$1" count_key="${base}.count"
  local count="${SYS[$count_key]:-0}"
  for ((i=0; i<count; i++)); do
    echo "${SYS[${base}.${i}]-}"
  done
}

# ──────────────────────────────────────────────
#  COLLECTORS
# ──────────────────────────────────────────────

# -- Machine --
collect_machine() {
  local hn hostid
  hn=$(hostname 2>/dev/null || uname -n)
  store "machine.hostname" "$hn"
  if [[ -f /sys/devices/virtual/dmi/id/product_name ]]; then
    store "machine.product" "$(safe_read_line /sys/devices/virtual/dmi/id/product_name)"
    store "machine.vendor" "$(safe_read_line /sys/devices/virtual/dmi/id/sys_vendor)"
    store "machine.family" "$(safe_read_line /sys/devices/virtual/dmi/id/product_family)"
    store "machine.uuid" "$(safe_read_line /sys/devices/virtual/dmi/id/product_uuid)"
  elif has_cmd dmidecode; then
    store "machine.product" "$(sudo dmidecode -s system-product-name 2>/dev/null || echo "unknown")"
    store "machine.vendor" "$(sudo dmidecode -s system-manufacturer 2>/dev/null || echo "unknown")"
  fi
  if [[ -f /sys/firmware/devicetree/base/model ]] && [[ -r /sys/firmware/devicetree/base/model ]]; then
    store "machine.dt_model" "$(< /sys/firmware/devicetree/base/model tr -d '\0')"
  fi
  chk=$(hostid 2>/dev/null)
  store "machine.hostid" "$chk"
}

# -- CPU --
collect_cpu() {
  local cpuinfo
  cpuinfo=$(safe_read /proc/cpuinfo) || true
  if [[ -z "$cpuinfo" ]]; then
    if has_cmd lscpu; then
      while IFS=':' read -r key val; do
        key="${key// /_}"
        key="${key,,}"
        val="${val## }"
        case "$key" in
          model_name) store "cpu.model" "$val" ;;
          cpu_mhz) store "cpu.mhz" "$(printf "%.0f" "$val" 2>/dev/null || echo "$val")" ;;
          cpu_max_mhz) store "cpu.max_mhz" "$(printf "%.0f" "$val" 2>/dev/null || echo "$val")" ;;
          cpu_min_mhz) store "cpu.min_mhz" "$(printf "%.0f" "$val" 2>/dev/null || echo "$val")" ;;
          architecture) store "cpu.arch" "$val" ;;
          cpu_socket*) store "cpu.sockets" "$val" ;;
          core_s*) store "cpu.cores_per_socket" "$val" ;;
          thread_s*) store "cpu.threads_per_core" "$val" ;;
          vendor_id) store "cpu.vendor" "$val" ;;
          flags) store "cpu.flags" "$val" ;;
          virtualization) store "cpu.virt" "$val" ;;
          bogomips) store "cpu.bogomips" "$val" ;;
        esac
      done < <(lscpu 2>/dev/null)
    fi
  else
    while IFS=':' read -r key val; do
      # Trim leading/trailing whitespace from key (but preserve internal spaces)
      key="${key#"${key%%[![:space:]]*}"}"
      key="${key%"${key##*[![:space:]]}"}"
      val="${val## }"
      case "$key" in
        "model name") store "cpu.model" "$val" ;;
        "cpu MHz"|"cpu MHz\t") store "cpu.mhz" "$(printf "%.0f" "$val" 2>/dev/null || echo "$val")" ;;
        vendor_id) store "cpu.vendor" "$val" ;;
        flags) store "cpu.flags" "$val" ;;
        "cpu cores") store "cpu.cores" "$val" ;;
        "cache size") store "cpu.cache" "$val" ;;
        model) store "cpu.model_id" "$val" ;;
        stepping) store "cpu.stepping" "$val" ;;
      esac
    done <<< "$cpuinfo"
  fi

  # Get CPU count from /proc/cpuinfo
  local core_count
  core_count=$(grep -c "^processor" /proc/cpuinfo 2>/dev/null || echo "0")
  store "cpu.logical" "$core_count"

  # Physical cores from topology
  local phys=0
  if [[ -d /sys/devices/system/cpu ]]; then
    for dir in /sys/devices/system/cpu/cpu[0-9]*/topology/core_id; do
      [[ -r "$dir" ]] || continue
      phys=$((phys + 1))
    done 2>/dev/null || true
  fi
  store "cpu.physical_total" "$phys"

  # Per-core frequencies
  if [[ -d /sys/devices/system/cpu ]]; then
    local idx=0
    for cpuf in /sys/devices/system/cpu/cpu[0-9]*/cpufreq/scaling_cur_freq; do
      if [[ -r "$cpuf" ]]; then
        local freq=$(< "$cpuf")
        freq=$((freq / 1000))
        store "cpu.core.${idx}.freq" "$freq"
        ((idx++)) || true
      fi
    done
    store "cpu.core_count" "$idx"
  fi

  # Load averages
  local loadavg
  loadavg=$(< /proc/loadavg) 2>/dev/null || true
  store "cpu.load_1m" "$(echo "${loadavg:-}" | awk '{print $1}')"
  store "cpu.load_5m" "$(echo "${loadavg:-}" | awk '{print $2}')"
  store "cpu.load_15m" "$(echo "${loadavg:-}" | awk '{print $3}')"
}

collect_cpu_usage() {
  local stat prev_idle prev_total
  stat=$(safe_read /proc/stat | head -1) || true
  local user nice sys idle iowait irq softirq steal
  read -r _ user nice sys idle iowait irq softirq steal <<< "$stat"
  prev_total=$((user + nice + sys + idle + iowait + irq + softirq + steal))
  prev_idle=$((idle + iowait))
  sleep 0.3
  stat=$(safe_read /proc/stat | head -1) || true
  read -r _ user nice sys idle iowait irq softirq steal <<< "$stat"
  local total=$((user + nice + sys + idle + iowait + irq + softirq + steal))
  local idl=$((idle + iowait))
  local total_d=$((total - prev_total))
  local idle_d=$((idl - prev_idle))
  if (( total_d > 0 )); then
    local usage=$(( 100 * (total_d - idle_d) / total_d ))
    store "cpu.usage_percent" "$usage"
  fi
}

# Cache lspci output to avoid repeated invocations
LSPCI_CACHED=""
LSPCI_MM_CACHED=""
cache_lspci() {
  [[ -z "$LSPCI_CACHED" ]] && LSPCI_CACHED=$(lspci 2>/dev/null || true)
  [[ -z "$LSPCI_MM_CACHED" ]] && LSPCI_MM_CACHED=$(lspci -mm 2>/dev/null || true)
}

# -- GPU --
collect_gpu() {
  cache_lspci
  local idx=0
  if [[ -n "$LSPCI_MM_CACHED" ]]; then
    while IFS= read -r line; do
      [[ "$line" =~ VGA|3D|Display ]] || continue
      local dev ven rev
      dev=$(echo "$line" | sed -n 's/^[^"]*"\([^"]*\)".*/\1/p')
      ven=$(echo "$line" | sed -n 's/^[^"]*"[^"]*"[[:space:]]*"\([^"]*\)".*/\1/p')
      rev=$(echo "$line" | sed -n 's/.*(rev \([^)]*\)).*/\1/p')
      store "gpu.${idx}.device" "$dev"
      store "gpu.${idx}.vendor" "$ven"
      store "gpu.${idx}.revision" "$rev"
      ((idx++)) || true
    done <<< "$LSPCI_MM_CACHED"
  fi
  store "gpu.count" "$idx"
  if [[ -d /sys/class/drm ]]; then
    for card in /sys/class/drm/card[0-9]*; do
      [[ -d "$card" ]] || continue
      local cname="${card##*/}"
      store "drm.${cname}.device" "$(safe_read_line "$card/device/device" 2>/dev/null)"
      store "drm.${cname}.vendor" "$(safe_read_line "$card/device/vendor" 2>/dev/null)"
      local mem
      mem=$(safe_read_line "$card/device/mem_info_vram_total" 2>/dev/null)
      [[ -n "$mem" ]] && store "drm.${cname}.vram" "$((mem / 1048576))"
    done
  fi
}

# -- Memory --
collect_memory() {
  local meminfo
  meminfo=$(safe_read /proc/meminfo) || true
  if [[ -n "$meminfo" ]]; then
    while IFS=':' read -r key val; do
      val="${val## }"
      val="${val% kB}"
      case "$key" in
        MemTotal)   store "memory.total_kb" "$val" ;&
        MemFree)    store "memory.free_kb" "$val" ;&
        MemAvailable) store "memory.avail_kb" "$val" ;&
        Buffers)    store "memory.buffers_kb" "$val" ;&
        Cached)     store "memory.cached_kb" "$val" ;&
        SwapTotal)  store "memory.swap_total_kb" "$val" ;&
        SwapFree)   store "memory.swap_free_kb" "$val" ;&
        Shmem)      store "memory.shared_kb" "$val" ;;
      esac
    done <<< "$meminfo"
  fi
  if has_cmd free; then
    store "memory.human" "$(free -h 2>/dev/null | awk '/^Mem:/{print $3"/"$2}')"
  fi
}

# -- Storage --
collect_storage() {
  local idx=0
  if has_cmd lsblk; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local name size type mount
      name=$(echo "$line" | awk '{print $1}')
      size=$(echo "$line" | awk '{print $2}')
      type=$(echo "$line" | awk '{print $3}')
      [[ "$type" != "disk" ]] && continue
      mount=$(echo "$line" | awk '{print $4}')
      local model
      model=$(lsblk -dln -o MODEL "/dev/$name" 2>/dev/null | head -1)
      model="${model:- }"
      store "storage.${idx}.name" "$name"
      store "storage.${idx}.size" "$size"
      store "storage.${idx}.model" "$model"
      ((idx++)) || true
    done < <(lsblk -dln -o NAME,SIZE,TYPE,MOUNTPOINT 2>/dev/null)
    store "storage.count" "$idx"
  fi

  # Filesystem usage from df
  local fidx=0
  while IFS= read -r line; do
    local fs size used avail use mount target
    fs=$(echo "$line" | awk '{print $1}')
    size=$(echo "$line" | awk '{print $2}')
    used=$(echo "$line" | awk '{print $3}')
    avail=$(echo "$line" | awk '{print $4}')
    use=$(echo "$line" | awk '{print $5}' | tr -d '%')
    mount=$(echo "$line" | awk '{print $6}')
    [[ "$fs" == "Filesystem" ]] && continue
    [[ "$fs" == "tmpfs" || "$fs" == "devtmpfs" || "$fs" == "efivarfs" ]] && continue
    [[ -z "$mount" ]] && continue
    store "fs.${fidx}.filesystem" "$fs"
    store "fs.${fidx}.size" "$size"
    store "fs.${fidx}.used" "$used"
    store "fs.${fidx}.avail" "$avail"
    store "fs.${fidx}.use_pct" "$use"
    store "fs.${fidx}.mount" "$mount"
    ((fidx++)) || true
  done < <(df -h 2>/dev/null | tail -n +2)
  store "fs.count" "$fidx"
}

# -- Battery --
collect_battery() {
  local bidx=0
  for bat in /sys/class/power_supply/BAT[0-9]*; do
    [[ -d "$bat" ]] || continue
    local name="${bat##*/}"
    store "battery.${bidx}.name" "$name"
    store "battery.${bidx}.status" "$(safe_read_line "$bat/status")"
    local cap
    cap=$(safe_read_line "$bat/capacity")
    store "battery.${bidx}.capacity" "$cap"
    local energy_full energy_now voltage_now
    energy_full=$(safe_read_line "$bat/energy_full" 2>/dev/null || echo "0")
    energy_now=$(safe_read_line "$bat/energy_now" 2>/dev/null || echo "0")
    voltage_now=$(safe_read_line "$bat/voltage_now" 2>/dev/null || echo "0")
    store "battery.${bidx}.energy_full" "$energy_full"
    store "battery.${bidx}.energy_now" "$energy_now"
    store "battery.${bidx}.voltage" "$voltage_now"
    store "battery.${bidx}.technology" "$(safe_read_line "$bat/technology")"
    store "battery.${bidx}.model" "$(safe_read_line "$bat/model_name")"
    store "battery.${bidx}.manufacturer" "$(safe_read_line "$bat/manufacturer")"

    # Compute watt-hours
    if [[ "$voltage_now" -gt 0 && "$energy_full" -gt 0 ]]; then
      local wh
      wh=$(bc -l <<< "$energy_full * $voltage_now / 1000000000000" 2>/dev/null || echo "0")
      store "battery.${bidx}.wh_design" "$(printf "%.1f" "$wh")"
    fi
    ((bidx++)) || true
  done
  store "battery.count" "$bidx"

  # Also check AC adapter
  local ac_idx=0
  for ac in /sys/class/power_supply/AC[0-9]*; do
    [[ -d "$ac" ]] || continue
    store "ac.${ac_idx}.online" "$(safe_read_line "$ac/online")"
    ((ac_idx++)) || true
  done
  store "ac.count" "$ac_idx"
}

# -- Fans --
collect_fans() {
  local fidx=0
  if has_cmd sensors; then
    while IFS= read -r line; do
      if [[ "$line" =~ ([0-9]+)\ RPM ]]; then
        local rpm="${BASH_REMATCH[1]}"
        local name="fan_${fidx}"
        # Try to get label
        local label=""
        if [[ "$line" =~ ^([^:]+): ]]; then
          label="${BASH_REMATCH[1]}"
        fi
        store "fan.${fidx}.name" "$label"
        store "fan.${fidx}.rpm" "$rpm"
        ((fidx++)) || true
      fi
    done < <(sensors 2>/dev/null || true)
  fi
  store "fan.count" "$fidx"

  # Also check hwmon
  if [[ -d /sys/class/hwmon ]]; then
    for hw in /sys/class/hwmon/hwmon[0-9]*; do
      for fan_input in "$hw"/fan[0-9]*_input; do
        [[ -r "$fan_input" ]] || continue
        local rpm_val
        rpm_val="$(< "$fan_input" tr -d ' \n')"
        local fname="${fan_input##*/}"
        fname="${fname%_input}"
        store "fan.hwmon.${fname}.rpm" "$rpm_val"
        # Try label
        local label
        label="$(safe_read_line "${fan_input%_input}_label")"
        store "fan.hwmon.${fname}.label" "$label"
      done
    done
  fi
}

# -- Temperatures --
collect_temps() {
  local tidx=0
  # From thermal zones
  for zone in /sys/class/thermal/thermal_zone[0-9]*; do
    [[ -d "$zone" ]] || continue
    local temp type
    temp=$(safe_read_line "$zone/temp" 2>/dev/null || echo "0")
    type=$(safe_read_line "$zone/type" 2>/dev/null || echo "unknown")
    if [[ "$temp" -gt 0 ]]; then
      local int=$((temp / 1000)) frac=$(((temp % 1000) / 100))
      store "temp.${tidx}.name" "$type"
      store "temp.${tidx}.celsius" "${int}.${frac}"
      ((tidx++)) || true
    fi
  done

  # From hwmon
  if [[ -d /sys/class/hwmon ]]; then
    for hw in /sys/class/hwmon/hwmon[0-9]*; do
      for temp_input in "$hw"/temp[0-9]*_input; do
        [[ -r "$temp_input" ]] || continue
        local tval tname
        tval="$(< "$temp_input" tr -d ' \n')"
        tname="${temp_input##*/}"
        tname="${tname%_input}"
        if [[ "$tval" -gt 0 ]]; then
          local int=$((tval / 1000)) frac=$(((tval % 1000) / 100))
          store "temp.hwmon.${tname}.celsius" "${int}.${frac}"
          local label
          label="$(safe_read_line "${temp_input%_input}_label")"
          store "temp.hwmon.${tname}.label" "$label"
        fi
      done
    done
  fi

  store "temp.count" "$tidx"
}

# -- Displays --
collect_displays() {
  local idx=0
  if has_cmd xrandr && [[ -n "${DISPLAY:-}" ]]; then
    while IFS= read -r line; do
      if [[ "$line" =~ ^([a-zA-Z0-9_-]+)\ connected ]]; then
        local display_name="${BASH_REMATCH[1]}"
        store "display.${idx}.name" "$display_name"
        if [[ "$line" =~ ([0-9]+)x([0-9]+)\+([0-9]+)\+([0-9]+) ]]; then
          store "display.${idx}.width" "${BASH_REMATCH[1]}"
          store "display.${idx}.height" "${BASH_REMATCH[2]}"
        fi
        if [[ "$line" =~ ([0-9.]+)mm\ x\ ([0-9.]+)mm ]]; then
          store "display.${idx}.width_mm" "${BASH_REMATCH[1]}"
          store "display.${idx}.height_mm" "${BASH_REMATCH[2]}"
        fi
        ((idx++)) || true
      fi
    done < <(xrandr --current 2>/dev/null || true)
  fi
  store "display.count" "$idx"

  # From /sys/class/drm as fallback
  if [[ "$idx" -eq 0 && -d /sys/class/drm ]]; then
    for card in /sys/class/drm/card[0-9]*/card[0-9]*-*-*; do
      [[ -d "$card" ]] || continue
      local edid="$card/edid"
      if [[ -r "$edid" && -f "$edid" ]]; then
        local man
        man=$(hexdump -n 4 -e '4/1 "%c"' "$edid" 2>/dev/null || echo "")
        store "display.${idx}.edid" "present"
        store "display.${idx}.name" "${card##*/}"
        ((idx++)) || true
      fi
    done
    store "display.count" "$idx"
  fi

  # /sys/class/backlight
  for bl in /sys/class/backlight/*/brightness; do
    [[ -r "$bl" ]] || continue
    local brightness max_brightness
    brightness=$(safe_read_line "$bl")
    max_brightness=$(safe_read_line "${bl%/*}/max_brightness")
    store "display.backlight" "$brightness"
    store "display.max_backlight" "$max_brightness"
  done
}

# -- Motherboard --
collect_motherboard() {
  if [[ -d /sys/devices/virtual/dmi/id ]]; then
    store "board.vendor" "$(safe_read_line /sys/devices/virtual/dmi/id/board_vendor)"
    store "board.name" "$(safe_read_line /sys/devices/virtual/dmi/id/board_name)"
    store "board.version" "$(safe_read_line /sys/devices/virtual/dmi/id/board_version)"
    store "board.serial" "$(safe_read_line /sys/devices/virtual/dmi/id/board_serial)"
    store "board.asset_tag" "$(safe_read_line /sys/devices/virtual/dmi/id/board_asset_tag)"
  elif has_cmd dmidecode; then
    store "board.vendor" "$(sudo dmidecode -s baseboard-manufacturer 2>/dev/null || echo "unknown")"
    store "board.name" "$(sudo dmidecode -s baseboard-product-name 2>/dev/null || echo "unknown")"
    store "board.version" "$(sudo dmidecode -s baseboard-version 2>/dev/null || echo "unknown")"
    store "board.serial" "$(sudo dmidecode -s baseboard-serial-number 2>/dev/null || echo "unknown")"
  fi
}

# -- BIOS --
collect_bios() {
  if [[ -d /sys/devices/virtual/dmi/id ]]; then
    store "bios.vendor" "$(safe_read_line /sys/devices/virtual/dmi/id/bios_vendor)"
    store "bios.version" "$(safe_read_line /sys/devices/virtual/dmi/id/bios_version)"
    store "bios.date" "$(safe_read_line /sys/devices/virtual/dmi/id/bios_date)"
    store "bios.release" "$(safe_read_line /sys/devices/virtual/dmi/id/bios_release)"
    store "bios.ec_firmware" "$(safe_read_line /sys/devices/virtual/dmi/id/ec_firmware_release)"
  elif has_cmd dmidecode; then
    store "bios.vendor" "$(sudo dmidecode -s bios-vendor 2>/dev/null || echo "unknown")"
    store "bios.version" "$(sudo dmidecode -s bios-version 2>/dev/null || echo "unknown")"
    store "bios.date" "$(sudo dmidecode -s bios-release-date 2>/dev/null || echo "unknown")"
  fi

  # UEFI detection
  if [[ -d /sys/firmware/efi ]]; then
    store "bios.mode" "UEFI"
  else
    store "bios.mode" "Legacy BIOS"
  fi
}

# -- Network --
collect_network() {
  local idx=0
  # From /sys/class/net
  for net in /sys/class/net/*; do
    [[ -d "$net" ]] || continue
    local ifname="${net##*/}"
    [[ "$ifname" == "lo" ]] && continue
    store "net.${idx}.name" "$ifname"
    store "net.${idx}.type" "$(safe_read_line "$net/type")"
    store "net.${idx}.address" "$(safe_read_line "$net/address")"
    local duplex speed
    duplex="$(safe_read_line "$net/duplex" 2>/dev/null || echo "")"
    speed="$(safe_read_line "$net/speed" 2>/dev/null || echo "")"
    store "net.${idx}.duplex" "$duplex"
    store "net.${idx}.speed" "$speed"
    local operstate
    operstate="$(safe_read_line "$net/operstate" 2>/dev/null || echo "unknown")"
    store "net.${idx}.state" "$operstate"
    ((idx++)) || true
  done
  store "net.count" "$idx"

  # Network traffic from /proc/net/dev
  while IFS= read -r line; do
    if [[ "$line" =~ ^[[:space:]]*([^:]+):[[:space:]]*(.*) ]]; then
      local dev_name="${BASH_REMATCH[1]}"
      local stats="${BASH_REMATCH[2]}"
      local rx_bytes tx_bytes
      rx_bytes=$(echo "$stats" | awk '{print $1}')
      tx_bytes=$(echo "$stats" | awk '{print $9}')
      for ((i=0; i<idx; i++)); do
        if [[ "$(get "net.${i}.name")" == "$dev_name" ]]; then
          store "net.${i}.rx_bytes" "$rx_bytes"
          store "net.${i}.tx_bytes" "$tx_bytes"
        fi
      done
    fi
  done < /proc/net/dev

  # Default route info
  local gw
  gw=$(ip route show default 2>/dev/null | awk '{print $3}') || true
  store "net.default_gateway" "$gw"
}

# -- Audio --
collect_audio() {
  cache_lspci
  local idx=0
  if [[ -n "$LSPCI_CACHED" ]]; then
    while IFS= read -r line; do
      [[ "$line" =~ Audio|HDMI|HDA|AC97 ]] || continue
      local dev
      dev=$(echo "$line" | sed 's/.*: //; s/ (.*//')
      store "audio.${idx}.device" "$dev"
      store "audio.${idx}.pci" "$(echo "$line" | awk '{print $1}')"
      ((idx++)) || true
    done <<< "$LSPCI_CACHED"
  fi
  store "audio.count" "$idx"

  # ALSA devices
  if [[ -d /proc/asound ]]; then
    local cards
    cards=$(safe_read /proc/asound/cards 2>/dev/null || echo "")
    if [[ -n "$cards" ]]; then
      store "audio.alsa_cards" "$(echo "$cards" | wc -l)"
    fi
    store "audio.alsa_info" "$(safe_read /proc/asound/version 2>/dev/null | head -1)"
  fi

  # PulseAudio / PipeWire
  if has_cmd pactl; then
    local sinks
    sinks=$(pactl list sinks short 2>/dev/null | wc -l)
    store "audio.pulse_sinks" "$sinks"
  fi
  if has_cmd pw-cli; then
    local nodes
    nodes=$(pw-cli list-nodes 2>/dev/null | grep -c "node.name") || nodes=0
    store "audio.pipewire_nodes" "$nodes"
  fi
}

# -- USB --
collect_usb() {
  if has_cmd lsusb; then
    local idx=0
    while IFS= read -r line; do
      if [[ "$line" =~ ^Bus ]]; then
        local bus dev id vendor product
        bus=$(echo "$line" | awk '{print $2}')
        dev=$(echo "$line" | awk '{print $4}' | tr -d ':')
        id=$(echo "$line" | awk '{print $6}')
        # Extract vendor:product names
        local desc
        desc=$(echo "$line" | sed 's/.*://; s/^[[:space:]]*//')
        store "usb.${idx}.bus" "$bus"
        store "usb.${idx}.device" "$dev"
        store "usb.${idx}.id" "$id"
        store "usb.${idx}.description" "$desc"
        ((idx++)) || true
      fi
    done < <(lsusb 2>/dev/null || true)
    store "usb.count" "$idx"
  fi
}

# -- PCI --
collect_pci() {
  cache_lspci
  local idx=0
  if [[ -n "$LSPCI_CACHED" ]]; then
    while IFS= read -r line; do
      local slot desc
      slot=$(echo "$line" | awk '{print $1}')
      desc=$(echo "$line" | sed 's/^[^ ]* //; s/ (.*//')
      store "pci.${idx}.slot" "$slot"
      store "pci.${idx}.description" "$desc"
      ((idx++)) || true
    done <<< "$LSPCI_CACHED"
    store "pci.count" "$idx"
  fi
}

# -- Operating System --
collect_os() {
  if [[ -f /etc/os-release ]]; then
    while IFS='=' read -r key val; do
      val="${val%\"}"
      val="${val#\"}"
      case "$key" in
        ID) store "os.id" "$val" ;;
        ID_LIKE) store "os.id_like" "$val" ;;
        PRETTY_NAME) store "os.pretty_name" "$val" ;;
        VERSION_ID) store "os.version_id" "$val" ;;
        VERSION_CODENAME) store "os.codename" "$val" ;;
        HOME_URL) store "os.home_url" "$val" ;;
      esac
    done < /etc/os-release
  elif [[ -f /etc/lsb-release ]]; then
    while IFS='=' read -r key val; do
      case "$key" in
        DISTRIB_ID) store "os.id" "$val" ;;
        DISTRIB_RELEASE) store "os.version_id" "$val" ;;
        DISTRIB_CODENAME) store "os.codename" "$val" ;;
        DISTRIB_DESCRIPTION) store "os.pretty_name" "$val" ;;
      esac
    done < /etc/lsb-release
  fi
  store "os.hostname" "$(hostname 2>/dev/null || uname -n)"
  store "os.arch" "$(uname -m)"
  store "os.user" "$(whoami 2>/dev/null || id -un)"
  local term
  term="${TERM:-unknown}"
  store "os.term" "$term"
  local shell
  shell="$(basename "${SHELL:-/bin/sh}")"
  store "os.shell" "$shell"
  local desktop
  desktop="${XDG_CURRENT_DESKTOP:-${DESKTOP_SESSION:-unknown}}"
  store "os.desktop" "$desktop"
  # Sessions
  local sessions
  sessions=$(who | wc -l)
  store "os.sessions" "$sessions"
}

# -- Kernel --
collect_kernel() {
  store "kernel.name" "$(uname -s)"
  store "kernel.release" "$(uname -r)"
  store "kernel.version" "$(uname -v)"
  store "kernel.machine" "$(uname -m)"
  local modules
  modules=$(lsmod 2>/dev/null | tail -n +2 | wc -l) || modules=0
  store "kernel.modules" "$modules"
  # Command line
  store "kernel.cmdline" "$(safe_read_line /proc/cmdline)"
}

# -- Security --
collect_security() {
  # AppArmor
  if [[ -d /sys/kernel/security/apparmor ]]; then
    store "security.apparmor" "enabled"
    local profiles
    profiles=$(cat /sys/kernel/security/apparmor/profiles 2>/dev/null | wc -l)
    store "security.apparmor_profiles" "$profiles"
  else
    store "security.apparmor" "disabled"
  fi

  # SELinux
  if has_cmd getenforce; then
    store "security.selinux" "$(getenforce 2>/dev/null)"
  else
    store "security.selinux" "not_present"
  fi

  # Firewall status
  if has_cmd ufw; then
    store "security.ufw" "$(ufw status 2>/dev/null | head -1)" || store "security.ufw" "unknown"
  elif has_cmd firewall-cmd; then
    store "security.firewalld" "$(firewall-cmd --state 2>/dev/null || echo "inactive")"
  elif has_cmd iptables; then
    local rules
    rules=$(iptables -L -n 2>/dev/null | grep -c "^Chain") || rules=0
    store "security.iptables_rules" "$rules"
  fi

  # ASLR
  if [[ -f /proc/sys/kernel/randomize_va_space ]]; then
    local aslr
    aslr=$(safe_read_line /proc/sys/kernel/randomize_va_space)
    case "$aslr" in
      0) store "security.aslr" "disabled" ;;
      1) store "security.aslr" "partial (randomize stack/libs)" ;;
      2) store "security.aslr" "full (randomize heap too)" ;;
    esac
  fi

  # Secure boot
  local sb_file
  sb_file=$(ls /sys/firmware/efi/efivars/SecureBoot-* 2>/dev/null | head -1) || true
  if [[ -n "$sb_file" && -f "$sb_file" ]]; then
    local sb
    sb=$(od -An -t u1 "$sb_file" 2>/dev/null | head -1 | awk '{print $2}')
    if [[ "$sb" == "1" ]]; then
      store "security.secure_boot" "enabled"
    elif [[ "$sb" == "0" ]]; then
      store "security.secure_boot" "disabled"
    else
      store "security.secure_boot" "unknown"
    fi
  else
    store "security.secure_boot" "N/A"
  fi

  # Yama ptrace scope
  if [[ -f /proc/sys/kernel/yama/ptrace_scope ]]; then
    local yama
    yama=$(safe_read_line /proc/sys/kernel/yama/ptrace_scope)
    store "security.ptrace_scope" "$yama"
  fi
}

# -- Virtualization --
collect_virtualization() {
  local virt=""
  # Check for hypervisor CPU flag
  local cpuinfo
  cpuinfo=$(safe_read /proc/cpuinfo)
  if echo "$cpuinfo" | grep -qi "hypervisor"; then
    virt="hypervisor"
  fi

  # Check DMI
  if [[ -f /sys/devices/virtual/dmi/id/product_name ]]; then
    local prod
    prod=$(safe_read_line /sys/devices/virtual/dmi/id/product_name)
    case "$prod" in
      *VMware*) virt="VMware" ;;
      *VirtualBox*) virt="VirtualBox" ;;
      *KVM*|*QEMU*) virt="KVM/QEMU" ;;
      *Xen*) virt="Xen" ;;
      *Microsoft*) virt="Hyper-V" ;;
      *Bochs*) virt="Bochs/QEMU" ;;
    esac
  fi

  # Check systemd
  if has_cmd systemd-detect-virt; then
    local sdv
    sdv=$(systemd-detect-virt 2>/dev/null) || sdv="none"
    [[ "$sdv" != "none" ]] && virt="$sdv"
  fi

  # Container detection
  if [[ -f /proc/1/cgroup ]]; then
    if grep -qi "docker" /proc/1/cgroup 2>/dev/null; then
      store "virtualization.container" "docker"
    fi
    if grep -qi "kubepods" /proc/1/cgroup 2>/dev/null; then
      store "virtualization.container" "kubernetes"
    fi
  fi

  store "virtualization.type" "${virt:-none}"
  store "virtualization.is_vm" "$( [[ -n "$virt" && "$virt" != "none" ]] && echo "yes" || echo "no" )"
}

# -- Uptime --
collect_uptime() {
  local uptime_secs
  uptime_secs=$(safe_read_line /proc/uptime 2>/dev/null | awk '{print $1}' | cut -d. -f1) || true
  if [[ -n "$uptime_secs" ]]; then
    local days=$((uptime_secs / 86400))
    local hours=$(( (uptime_secs % 86400) / 3600 ))
    local mins=$(( (uptime_secs % 3600) / 60 ))
    local secs=$(( uptime_secs % 60 ))
    store "uptime.seconds" "$uptime_secs"
    store "uptime.display" "${days}d ${hours}h ${mins}m ${secs}s"
    store "uptime.days" "$days"
    store "uptime.hours" "$hours"
    store "uptime.minutes" "$mins"
    store "uptime.seconds_only" "$secs"

    # Boot time
    if [[ -f /proc/stat ]]; then
      local btime
      btime=$(grep "^btime" /proc/stat 2>/dev/null | awk '{print $2}')
      store "uptime.boot_time" "$btime"
    fi
  fi
}

# -- Processes --
collect_processes() {
  local total running sleeping zombie stopped
  total=$(ps -e 2>/dev/null | wc -l) || total=0
  if [[ -z "$total" || "$total" -eq 0 ]]; then
    total=$(ls /proc/[0-9]* 2>/dev/null | wc -l) || total=0
  fi
  store "process.total" "$((total - 1))"

  running=$(ps -e -o state= 2>/dev/null | grep -c "^R") || running=0
  sleeping=$(ps -e -o state= 2>/dev/null | grep -c "^S") || sleeping=0
  zombie=$(ps -e -o state= 2>/dev/null | grep -c "^Z") || zombie=0
  stopped=$(ps -e -o state= 2>/dev/null | grep -c "^T") || stopped=0

  store "process.running" "$running"
  store "process.sleeping" "$sleeping"
  store "process.zombie" "$zombie"
  store "process.stopped" "$stopped"

  # Top processes by CPU
  local top_idx=0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local pid cpu mem cmd
    pid=$(echo "$line" | awk '{print $1}')
    cpu=$(echo "$line" | awk '{print $3}')
    mem=$(echo "$line" | awk '{print $4}')
    cmd=$(echo "$line" | awk '{for(i=6;i<=NF;i++) printf "%s ", $i; print ""}' | xargs | head -c 55)
    [[ "$top_idx" -ge 10 ]] && break
    store "process.top.${top_idx}.pid" "$pid"
    store "process.top.${top_idx}.cpu" "$cpu"
    store "process.top.${top_idx}.mem" "$mem"
    store "process.top.${top_idx}.cmd" "$cmd"
    ((top_idx++)) || true
  done < <(ps -eo pid,ppid,%cpu,%mem,rss,args --sort=-%cpu 2>/dev/null | tail -n +2 | head -10)
  store "process.top_count" "$top_idx"
}

# -- System load (doctor helper) --
collect_system_load() {
  local fd=0
  local p fds
  for p in /proc/[0-9]*/fd; do
    [[ -d "$p" ]] || continue
    fds=("$p"/*)
    fd=$((fd + ${#fds[@]}))
  done
  store "system.fd_count" "$fd"
  # Number of logged in users
  store "system.users" "$(users | wc -w)"
  # Running services
  if has_cmd systemctl; then
    local svc
    svc=$(systemctl list-units --type=service --state=running 2>/dev/null | grep -c "running") || svc=0
    store "system.services_running" "$svc"
  fi
}

# ──────────────────────────────────────────────
#  COLLECT ALL (runs all collectors)
