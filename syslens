    th{color:#8b949e} tr:hover{background:#161b22}
    .footer{margin-top:40px;color:#8b949e;font-size:12px;text-align:center}
  </style>"
  printf "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><title>syslens - %s</title>%s</head><body>\n" "$(get machine.hostname)" "$style"
  printf "<h1>syslens System Report</h1><p><strong>Host:</strong> %s | <strong>Date:</strong> %s</p>\n" "$(get machine.hostname)" "$(date '+%Y-%m-%d %H:%M:%S')"
  local sections=(
    "Machine|machine.hostname|Hostname|machine.product|Product|machine.vendor|Vendor"
    "CPU|cpu.model|Model|cpu.logical|Cores|cpu.mhz|MHz"
    "Memory|memory.total_kb|Total (KiB)|memory.avail_kb|Available (KiB)"
    "OS|os.pretty_name|OS|os.version_id|Version|os.arch|Architecture"
    "Kernel|kernel.release|Release|kernel.version|Version"
  )
  for entry in "${sections[@]}"; do
    local title="${entry%%|*}" rest="${entry#*|}" has_data=false rows=""
    IFS='|' read -ra fields <<< "$rest"
    for ((j=0; j<${#fields[@]}; j+=2)); do
      local fval="$(get "${fields[$j]}")"
      if [[ -n "$fval" && "$fval" != "0" && "$fval" != "unknown" ]]; then
        has_data=true; rows+="<tr><td>${fields[$((j+1))]}</td><td>$fval</td></tr>"
      fi
    done
    $has_data && printf "<h2>%s</h2>\n<table>\n%s\n</table>\n" "$title" "$rows"
  done
