          printf "| OS | %s |\n" "$(get os.pretty_name)"
          printf "| Version | %s |\n" "$(get os.version_id)"
          printf "| Architecture | %s |\n" "$(get os.arch)"
          printf "| Hostname | %s |\n" "$(get os.hostname)"
          printf "| User | %s |\n" "$(get os.user)"
          printf "| Desktop | %s |\n" "$(get os.desktop)"
          printf "| Shell | %s |\n" "$(get os.shell)"
          printf "| Terminal | %s |\n" "$(get os.term)"
        fi
        ;;
      CPU)
        if [[ -n "$(get cpu.model)" ]]; then
          has_data=true
          printf "## CPU\n\n"
          printf "| Key | Value |\n| --- | --- |\n"
          printf "| Model | %s |\n" "$(get cpu.model)"
          printf "| Cores | %s logical, %s physical |\n" "$(get cpu.logical)" "$(get cpu.physical_total)"
          printf "| Frequency | %s MHz |\n" "$(get cpu.mhz)"
          printf "| Load | %s / %s / %s |\n" "$(get cpu.load_1m)" "$(get cpu.load_5m)" "$(get cpu.load_15m)"
        fi
        ;;
      Memory)
        if [[ -n "$(get memory.total_kb)" ]]; then
          has_data=true
          printf "## Memory\n\n"
          printf "| Key | Value |\n| --- | --- |\n"
          printf "| Total | %d MiB |\n" "$(($(get memory.total_kb) / 1024))"
          printf "| Available | %d MiB |\n" "$(($(get memory.avail_kb) / 1024))"
          printf "| Free | %d MiB |\n" "$(($(get memory.free_kb) / 1024))"
          printf "| Swap Total | %d MiB |\n" "$(($(get memory.swap_total_kb) / 1024))"
        fi
        ;;
      Battery)
        local bc=$(get battery.count)
        if [[ "$bc" -gt 0 ]]; then
          has_data=true
          printf "## Battery\n\n"
          for ((i=0; i<bc; i++)); do
            printf "- **%s**: %s%% (%s)\n" "$(get battery.${i}.name)" "$(get battery.${i}.capacity)" "$(get battery.${i}.status)"
          done
        fi
        ;;
      Fans)
        local fc=$(get fan.count)
        if [[ "$fc" -gt 0 ]]; then
          has_data=true
          printf "## Fans\n\n"
          for ((i=0; i<fc; i++)); do
            printf "- %s: %s RPM\n" "$(get fan.${i}.name)" "$(get fan.${i}.rpm)"
          done
        fi
        ;;
      Temps)
        local tc=$(get temp.count)
        if [[ "$tc" -gt 0 ]]; then
          has_data=true
          printf "## Temperatures\n\n"
          for ((i=0; i<tc; i++)); do
            printf "- %s: %s°C\n" "$(get temp.${i}.name)" "$(get temp.${i}.celsius)"
          done
        fi
        ;;
      Network)
        local nc=$(get net.count)
        if [[ "$nc" -gt 0 ]]; then
          has_data=true
          printf "## Network\n\n"
          for ((i=0; i<nc; i++)); do
            printf "- **%s**: %s (%s)\n" "$(get net.${i}.name)" "$(get net.${i}.address)" "$(get net.${i}.state)"
          done
        fi
        ;;
      Uptime)
        if [[ -n "$(get uptime.display)" ]]; then
          has_data=true
          printf "## Uptime\n\n"
          printf "%s\n" "$(get uptime.display)"
        fi
        ;;
      Processes)
        if [[ -n "$(get process.total)" ]]; then
          has_data=true
          printf "## Processes\n\n"
          printf "- Total: %s\n" "$(get process.total)"
          printf "- Running: %s\n" "$(get process.running)"
          printf "- Zombie: %s\n" "$(get process.zombie)"
        fi
        ;;
    esac
  done

  # Print any sections not covered above
  printf "\n---\n*Generated by syslens v%s on %s*\n" "$VERSION" "$(date '+%Y-%m-%d %H:%M:%S')"
}

