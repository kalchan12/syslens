cmd_doctor() {
  collect_all_with_usage
  printf "\n${BOLD}${UNDER}syslens Health Report${NC} ${D}v${VERSION}${NC}\n"
  printf "${D}%s${NC}\n" "$(printf "%0.s─" $(seq 1 62))"

  local issues=0

  # Memory check
  local total_kb=$(get memory.total_kb)
  local avail_kb=$(get memory.avail_kb)
  if [[ "$total_kb" -gt 0 ]]; then
    local pct=$(( (total_kb - avail_kb) * 100 / total_kb ))
    if (( pct > 90 )); then
      printf "${R}✗${NC} Memory usage critical: %d%%\n" "$pct"
      ((issues++)) || true
    elif (( pct > 75 )); then
      printf "${Y}⚠${NC} Memory usage high: %d%%\n" "$pct"
      ((issues++)) || true
    else
      printf "${G}✓${NC} Memory usage normal: %d%%\n" "$pct"
    fi
  fi

  # CPU load
  local load_1m=$(get cpu.load_1m)
  local logical=$(get cpu.logical)
  if [[ -n "$load_1m" && -n "$logical" && "$logical" -gt 0 ]]; then
    if (( $(bc -l <<< "$load_1m > $logical * 0.9" 2>/dev/null || echo 0) )); then
      printf "${Y}⚠${NC} CPU load high: %s (threshold: %s)\n" "$load_1m" "$logical"
      ((issues++)) || true
    else
      printf "${G}✓${NC} CPU load normal: %s (cores: %s)\n" "$load_1m" "$logical"
    fi
  fi

  # Temperature check
  local tc=$(get temp.count)
  for ((i=0; i<tc; i++)); do
    local celsius=$(get "temp.${i}.celsius")
    local name=$(get "temp.${i}.name")
    local cint=${celsius%.*}
    if [[ -n "$celsius" && "$cint" -ge 80 ]]; then
      printf "${R}✗${NC} Temperature critical: %s = %s°C\n" "$name" "$celsius"
      ((issues++)) || true
    elif [[ -n "$celsius" && "$cint" -ge 60 ]]; then
      printf "${Y}⚠${NC} Temperature high: %s = %s°C\n" "$name" "$celsius"
      ((issues++)) || true
    fi
  done

  # Battery check
  local bc=$(get battery.count)
  for ((i=0; i<bc; i++)); do
    local cap=$(get "battery.${i}.capacity")
    if [[ -n "$cap" && "$cap" -lt 20 ]]; then
      printf "${Y}⚠${NC} Battery %s capacity critical: %s%%\n" "$(get battery.${i}.name)" "$cap"
      ((issues++)) || true
    elif [[ -n "$cap" && "$cap" -lt 50 ]]; then
      printf "${Y}⚠${NC} Battery %s capacity low: %s%%\n" "$(get battery.${i}.name)" "$cap"
      ((issues++)) || true
    fi
  done

  # Swap check
  local swap_total_kb=$(get memory.swap_total_kb)
  local swap_free_kb=$(get memory.swap_free_kb)
  if [[ -n "$swap_total_kb" && "$swap_total_kb" -gt 0 ]]; then
    local swap_pct=$(( (swap_total_kb - swap_free_kb) * 100 / swap_total_kb ))
    if (( swap_pct > 80 )); then
      printf "${Y}⚠${NC} Swap usage high: %d%%\n" "$swap_pct"
      ((issues++)) || true
    else
      printf "${G}✓${NC} Swap usage normal: %d%%\n" "$swap_pct"
    fi
  fi

  # Filesystem checks
  local fcount=$(get fs.count)
  for ((i=0; i<fcount; i++)); do
    local use_pct=$(get "fs.${i}.use_pct")
    local mount=$(get "fs.${i}.mount")
    if [[ -n "$use_pct" && "$use_pct" -gt 90 ]]; then
      printf "${R}✗${NC} Disk %s usage critical: %d%%\n" "$mount" "$use_pct"
      ((issues++)) || true
    elif [[ -n "$use_pct" && "$use_pct" -gt 75 ]]; then
      printf "${Y}⚠${NC} Disk %s usage high: %d%%\n" "$mount" "$use_pct"
      ((issues++)) || true
    fi
  done

  # Zombie processes
  local zombie=$(get process.zombie)
  if [[ -n "$zombie" && "$zombie" -gt 0 ]]; then
    printf "${Y}⚠${NC} Zombie processes: %s\n" "$zombie"
    ((issues++)) || true
  fi

  # Uptime
  local days=$(get uptime.days)
  if [[ -n "$days" && "$days" -gt 60 ]]; then
    printf "${Y}⚠${NC} System has been up for %s days - consider rebooting\n" "$days"
    ((issues++)) || true
  fi

  # Kernel security
  local aslr=$(get security.aslr)
  if [[ "$aslr" =~ disabled ]]; then
    printf "${R}✗${NC} ASLR is disabled!\n"
    ((issues++)) || true
  fi

  local yama=$(get security.ptrace_scope)
  if [[ -n "$yama" && "$yama" -eq 0 ]]; then
    printf "${Y}⚠${NC} Ptrace scope is 0 (any process can trace)\n"
    ((issues++)) || true
  fi

  # Summary
  printf "${D}%s${NC}\n" "$(printf "%0.s─" $(seq 1 62))"
  if [[ "$issues" -eq 0 ]]; then
    printf "${G}✓${NC} All checks passed - system appears healthy\n"
  else
    printf "${Y}⚠${NC} %d potential issue(s) found\n" "$issues"
  fi
  printf "\n"
}

# ──────────────────────────────────────────────
#  SNAPSHOT COMMANDS
# ──────────────────────────────────────────────

cmd_snapshot_save() {
  mkdir -p "$SNAPSHOT_DIR"
  collect_all_with_usage
  local timestamp
  timestamp=$(date '+%Y%m%d_%H%M%S')
  local hostname=$(get machine.hostname)
  local file="${SNAPSHOT_DIR}/${hostname}_${timestamp}.json"
  export_json > "$file"
  printf "${G}✓${NC} Snapshot saved: ${B}%s${NC}\n" "$file"
}

cmd_snapshot_list() {
  mkdir -p "$SNAPSHOT_DIR"
  local files=("$SNAPSHOT_DIR"/*.json)
  if [[ ! -e "${files[0]}" ]]; then
    printf "${Y}No snapshots found.${NC}\n"
    return
  fi
  printf "${BOLD}Saved Snapshots:${NC}\n"
  for f in "${files[@]}"; do
    local fname="${f##*/}"
    local host="${fname%_*}"
    local ts="${fname#*_}"
    ts="${ts%.json}"
    ts="${ts/_/ }"
    local size
    size=$(du -h "$f" | cut -f1)
    printf "  ${D}%s${NC}  %s  ${D}(%s)${NC}\n" "$host" "$ts" "$size"
  done
}

cmd_snapshot_diff() {
  local files=("$SNAPSHOT_DIR"/*.json)
  if [[ ! -e "${files[0]}" ]]; then
    printf "${R}No snapshots found.${NC}\n"
    return
  fi

  local target=""
  if [[ -n "${1:-}" ]]; then
    target="$1"
  else
    # Use the latest
    target="${files[${#files[@]}-1]}"
  fi

  if [[ ! -f "$target" ]]; then
    printf "${R}Snapshot not found: %s${NC}\n" "$target"
    return
  fi

  printf "${BOLD}Comparing with snapshot:${NC} ${D}%s${NC}\n\n" "${target##*/}"

  # Collect current data
  collect_all_with_usage
  local current_json
  current_json=$(export_json)

  # Compare using python if available
  if has_cmd python3; then
    python3 -c "
import json, sys

with open('$target') as f:
    old = json.load(f)

current = json.loads('''$current_json''')

def flatten(d, prefix=''):
    items = []
    for k, v in d.items():
        if isinstance(v, dict):
            items.extend(flatten(v, prefix + k + '.'))
        else:
            items.append((prefix + k, v))
    return items

old_flat = dict(flatten(old))
cur_flat = dict(flatten(current))

changed = 0
added = 0
removed = 0

for k in sorted(set(list(old_flat.keys()) + list(cur_flat.keys()))):
    old_val = old_flat.get(k, '<MISSING>')
    cur_val = cur_flat.get(k, '<MISSING>')
    if old_val != cur_val:
        if k in old_flat and k not in cur_flat:
            print(f'  REMOVED  {k}: {old_val}')
            removed += 1
        elif k not in old_flat and k in cur_flat:
            print(f'  ADDED    {k}: {cur_val}')
            added += 1
        else:
            print(f'  CHANGED  {k}: {old_val} -> {cur_val}')
            changed += 1

if changed == 0 and added == 0 and removed == 0:
    print('  No changes detected.')
else:
    print(f'\nSummary: {changed} changed, {added} added, {removed} removed')
" 2>/dev/null || {
      warn "Python3 required for diff functionality"
    }
  else
    warn "Python3 required for snapshot comparison"
  fi
}

# ──────────────────────────────────────────────
#  WATCH MODE
# ──────────────────────────────────────────────

cmd_watch() {
  local interval="${1:-2}"
  printf "${C}syslens${NC} ${D}watch mode (every ${interval}s) - Ctrl+C to stop${NC}\n"
  while true; do
    # Clear screen
    printf "\033[H\033[J"
    local date_str
    date_str=$(date '+%Y-%m-%d %H:%M:%S')
    printf "${BOLD}${C}syslens${NC} ${D}watch • %s${NC}\n" "$date_str"
    printf "${D}%s${NC}\n" "$(printf "%0.s─" $(seq 1 62))"

    unset SYS
    declare -gA SYS
    collect_all_with_usage

    # Render compact view
    render_cpu_compact
    render_memory_compact
    render_storage_compact
    render_temps_compact
    render_uptime_compact

    printf "${D}%s${NC}\n" "$(printf "%0.s─" $(seq 1 62))"
    sleep "$interval"
  done
}

render_cpu_compact() {
  local model=$(get cpu.model)
  local load1=$(get cpu.load_1m)
  local load5=$(get cpu.load_5m)
  local load15=$(get cpu.load_15m)
  local usage=$(get cpu.usage_percent)

  local usage_str="" usage_col=$G
  if [[ -n "$usage" ]]; then
    (( usage > 80 )) && usage_col=$R
    (( usage >= 50 && usage <= 80 )) && usage_col=$Y
    usage_str="${usage_col}${usage}%${NC}"
  else
    usage_str="${D}N/A${NC}"
  fi

  printf "${B}CPU:${NC} %s\n" "$model"
  printf "  ${D}Load:${NC} %s %s %s  ${D}Usage:${NC} %s  ${D}Cores:${NC} %s\n" \
    "$load1" "$load5" "$load15" "$usage_str" "$(get cpu.logical)"
}

render_memory_compact() {
  local total_mib=$(($(get memory.total_kb) / 1024))
  local avail_mib=$(($(get memory.avail_kb) / 1024))
  local used_mib=$((total_mib - avail_mib))
  local pct=$(( (total_mib - avail_mib) * 100 / total_mib ))

  local bar_len=25
  local filled=$(( pct * bar_len / 100 ))
  local bar="["
  local col=$G
  (( pct > 80 )) && col=$R
  (( pct >= 50 && pct <= 80 )) && col=$Y
  bar+="$col"
  for ((i=0; i<filled; i++)); do bar+="█"; done
  bar+="$D"
  for ((i=0; i<bar_len-filled; i++)); do bar+="░"; done
  bar+="$NC]"
  printf "${B}MEM:${NC} %s %s/%s MiB (%d%%)\n" "$bar" "$used_mib" "$total_mib" "$pct"
}

render_storage_compact() {
  local fcount=$(get fs.count)
  printf "${B}FS:${NC} "
  local shown=0
  for ((i=0; i<fcount; i++)); do
    local mount=$(get "fs.${i}.mount")
    local use_pct=$(get "fs.${i}.use_pct")
    [[ "$mount" == "/" || "$mount" == "/home" || "$mount" == "/boot" ]] || continue
    local col=$G
    (( use_pct > 90 )) && col=$R
    (( use_pct >= 75 && use_pct <= 90 )) && col=$Y
    printf "${col}%s %s%%${NC}  " "$mount" "$use_pct"
    ((shown++)) || true
  done
  (( shown == 0 )) && printf "${D}N/A${NC}"
  printf "\n"
}

render_temps_compact() {
  local tc=$(get temp.count)
  printf "${B}TEMP:${NC} "
  local shown=0
  for ((i=0; i<tc; i++)); do
    local name=$(get "temp.${i}.name")
    local celsius=$(get "temp.${i}.celsius")
    local cint=${celsius%.*}
    local col=$G
    (( cint >= 80 )) && col=$R
    (( cint >= 60 && cint < 80 )) && col=$Y
    # Show only relevant sensors
    if echo "$name" | grep -qiE "cpu|core|package|pch|soc|gpu"; then
      printf "${col}%s %s°C${NC}  " "$name" "$celsius"
      ((shown++)) || true
    fi
  done
  (( shown == 0 )) && printf "${D}N/A${NC}"
  printf "\n"
}

render_uptime_compact() {
  printf "${B}UP:${NC} %s\n" "$(get uptime.display)"
}

